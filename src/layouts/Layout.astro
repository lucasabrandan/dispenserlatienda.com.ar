---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Servicio Técnico Dispensers CABA y AMBA | Dispenser La Tienda",
  description = "Reparación, mantenimiento y limpieza de dispensers de agua a domicilio en CABA y AMBA. Respuesta inmediata por WhatsApp. Visita en 24-48 horas. 011 6608-2608.",
} = Astro.props;
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/logo.png" />

    <!-- Canonical -->
    <link rel="canonical" href="https://dispenserlatienda.com.ar" />

    <!-- Open Graph -->
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content="https://dispenserlatienda.com.ar" />
    <meta property="og:type"        content="website" />
    <meta property="og:locale"      content="es_AR" />
    <meta property="og:image"       content="https://dispenserlatienda.com.ar/og-image.webp" />
    <meta property="og:image:alt"   content="Dispenser de agua frío y calor — Dispenser La Tienda" />
    <meta property="og:site_name"   content="Dispenser La Tienda" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content="https://dispenserlatienda.com.ar/og-image.webp" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Dispenser La Tienda",
        "description": "Servicio técnico de dispensers de agua a domicilio en CABA y AMBA. Reparación, limpieza y mantenimiento con garantía incluida.",
        "slogan": "Reparación y limpieza de dispensers a domicilio.",
        "telephone": "+54-9-11-6608-2608",
        "email": "info@dispenserlatienda.com.ar",
        "url": "https://dispenserlatienda.com.ar",
        "areaServed": ["Ciudad Autónoma de Buenos Aires", "Area Metropolitana de Buenos Aires"],
        "openingHours": "Mo-Sa 09:00-18:00",
        "sameAs": [
          "https://www.tiktok.com/@dispenserlatienda",
          "https://www.instagram.com/dispenserlatienda/"
        ]
      }
    </script>
  </head>

  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Scroll to top FAB -->
    <button
      type="button"
      id="scroll-top-btn"
      class="scroll-top-btn"
      aria-label="Volver arriba"
    >
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="18 15 12 9 6 15"/>
      </svg>
    </button>

    <!-- Reveal animation observer -->
    <script>
      const els = document.querySelectorAll(".reveal");
      if (!("IntersectionObserver" in window)) {
        els.forEach(el => el.classList.add("is-visible"));
      } else {
        const io = new IntersectionObserver(
          entries => entries.forEach(e => {
            if (e.isIntersecting) e.target.classList.add("is-visible");
            else e.target.classList.remove("is-visible");
          }),
          { threshold: 0.15 }
        );
        els.forEach(el => io.observe(el));
      }
    </script>

    <!-- Scroll to top behavior -->
    <script>
      const scrollBtn = document.getElementById("scroll-top-btn");
      if (scrollBtn) {
        const SHOW_AFTER = 400;
        const onScroll = () => {
          scrollBtn.classList.toggle("is-visible", window.scrollY > SHOW_AFTER);
        };
        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
        scrollBtn.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }
    </script>
  </body>
</html>

<style>
  .scroll-top-btn {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 100;
    width: 48px;
    height: 48px;
    background: var(--brand);
    border: 0;
    border-radius: 50%;
    display: grid;
    place-items: center;
    color: #fff;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(255, 123, 3, 0.4);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: opacity 0.25s, transform 0.25s, visibility 0.25s, background 0.2s;
  }
  .scroll-top-btn.is-visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .scroll-top-btn:hover {
    background: var(--brand-d);
  }
  .scroll-top-btn.is-visible:hover {
    transform: translateY(-2px);
  }
</style>
