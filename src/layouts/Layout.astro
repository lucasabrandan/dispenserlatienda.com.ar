---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE, PHONE, EMAIL, SOCIAL, COBERTURA, REVIEWS, ANALYTICS, HORARIO, SHEETS_WEBHOOK } from "../config/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `Servicio Técnico Dispensers ${COBERTURA.short} | ${SITE.name}`,
  description = `Reparación, mantenimiento y limpieza de dispensers de agua a domicilio en ${COBERTURA.short}. Respuesta inmediata por WhatsApp. Visita en 24-48 horas. ${PHONE.display}.`,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, SITE.url).href;

// Schema.org — LocalBusiness con AggregateRating
const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": SITE.name,
  "description": SITE.description,
  "slogan": SITE.slogan,
  "telephone": PHONE.international,
  "email": EMAIL,
  "url": SITE.url,
  "areaServed": ["Ciudad Autónoma de Buenos Aires", "Gran Buenos Aires"],
  "openingHours": HORARIO.schema,
  "sameAs": [SOCIAL.tiktok, SOCIAL.instagram],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": REVIEWS.rating,
    "reviewCount": REVIEWS.count,
    "bestRating": 5,
    "worstRating": 1,
  },
};
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/webp" href="/logo.webp" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonicalUrl} />
    <meta property="og:type"        content="website" />
    <meta property="og:locale"      content="es_AR" />
    <meta property="og:image"       content={`${SITE.url}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt"   content={`${SITE.name} — Servicio técnico de dispensers`} />
    <meta property="og:site_name"   content={SITE.name} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={`${SITE.url}/og-image.png`} />

    <!-- Google Search Console verification (activar cuando se tenga el ID) -->
    {ANALYTICS.searchConsoleId && (
      <meta name="google-site-verification" content={ANALYTICS.searchConsoleId} />
    )}

    <!-- Google Fonts — variable font (single request, all weights) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400..900&display=swap"
      rel="stylesheet"
    />

    <!-- Webhook Google Sheets (para formulario de contacto) -->
    {SHEETS_WEBHOOK && (
      <script is:inline define:vars={{ sheetsUrl: SHEETS_WEBHOOK }}>
        window.__SHEETS_WEBHOOK__ = sheetsUrl;
      </script>
    )}

    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />

    <!-- GA4 (inactivo hasta pegar Measurement ID) -->
    {ANALYTICS.ga4Id && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${ANALYTICS.ga4Id}`} />
        <script is:inline define:vars={{ ga4Id: ANALYTICS.ga4Id }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){window.dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('consent', 'default', {
            analytics_storage: 'denied',
            ad_storage: 'denied',
          });
          gtag('config', ga4Id);
        </script>
      </>
    )}

    <!-- Meta Pixel (inactivo hasta pegar ID) -->
    {ANALYTICS.metaPixelId && (
      <script is:inline define:vars={{ pixelId: ANALYTICS.metaPixelId }}>
        !function(f,b,e,v,n,t,s)
        {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};
        if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
        n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t,s)}(window, document,'script',
        'https://connect.facebook.net/en_US/fbevents.js');
        fbq('consent', 'revoke');
        fbq('init', pixelId);
        fbq('track', 'PageView');
      </script>
    )}
  </head>

  <body>
    <!-- Cookie Consent Banner -->
    <div id="cookie-banner" class="cookie-banner" role="dialog" aria-label="Consentimiento de cookies" style="display:none;">
      <div class="cookie-inner">
        <p class="cookie-text">
          Usamos cookies para medir el rendimiento del sitio y mejorar tu experiencia.
          Podés aceptar o rechazar las opcionales.
        </p>
        <div class="cookie-actions">
          <button type="button" id="cookie-reject" class="cookie-btn cookie-btn--reject">Solo esenciales</button>
          <button type="button" id="cookie-accept" class="cookie-btn cookie-btn--accept">Aceptar todas</button>
        </div>
      </div>
    </div>

    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Scroll to top FAB -->
    <button
      type="button"
      id="scroll-top-btn"
      class="scroll-top-btn"
      aria-label="Volver arriba"
    >
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="18 15 12 9 6 15"/>
      </svg>
    </button>

    <!-- Cookie consent logic -->
    <script is:inline>
      (function() {
        var banner = document.getElementById('cookie-banner');
        var stored = localStorage.getItem('cookie-consent');

        if (!stored) {
          banner.style.display = '';
        }

        function updateConsent(accepted) {
          localStorage.setItem('cookie-consent', accepted ? 'all' : 'essential');
          banner.style.display = 'none';

          if (typeof gtag === 'function') {
            gtag('consent', 'update', {
              analytics_storage: accepted ? 'granted' : 'denied',
              ad_storage: accepted ? 'granted' : 'denied',
            });
          }
          if (typeof fbq === 'function') {
            if (accepted) fbq('consent', 'grant');
          }
        }

        document.getElementById('cookie-accept').addEventListener('click', function() { updateConsent(true); });
        document.getElementById('cookie-reject').addEventListener('click', function() { updateConsent(false); });

        // Restaurar consentimiento al cargar
        if (stored === 'all') {
          if (typeof gtag === 'function') {
            gtag('consent', 'update', { analytics_storage: 'granted', ad_storage: 'granted' });
          }
          if (typeof fbq === 'function') fbq('consent', 'grant');
        }
      })();
    </script>

    <!-- Tracking de clics a WhatsApp -->
    <script is:inline>
      window.trackWaClick = function(origin) {
        // GA4 event
        if (typeof gtag === 'function') {
          gtag('event', 'wa_click', {
            event_category: 'conversion',
            event_label: origin,
          });
        }
        // Meta Pixel event
        if (typeof fbq === 'function') {
          fbq('trackCustom', 'WhatsAppClick', { origin: origin });
        }
      };

      document.addEventListener('click', function(e) {
        var link = e.target.closest('[data-wa-event]');
        if (link) {
          window.trackWaClick(link.dataset.waEvent);
        }
      });
    </script>

    <!-- Reveal animation observer -->
    <script>
      const els = document.querySelectorAll(".reveal");
      if (!("IntersectionObserver" in window)) {
        els.forEach(el => el.classList.add("is-visible"));
      } else {
        const io = new IntersectionObserver(
          entries => entries.forEach(e => {
            if (e.isIntersecting) e.target.classList.add("is-visible");
            else e.target.classList.remove("is-visible");
          }),
          { threshold: 0.15 }
        );
        els.forEach(el => io.observe(el));
      }
    </script>

    <!-- Scroll to top behavior -->
    <script>
      const scrollBtn = document.getElementById("scroll-top-btn");
      if (scrollBtn) {
        const SHOW_AFTER = 400;
        const onScroll = () => {
          scrollBtn.classList.toggle("is-visible", window.scrollY > SHOW_AFTER);
        };
        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
        scrollBtn.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }
    </script>
  </body>
</html>

<style>
  /* Cookie Banner */
  .cookie-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 200;
    background: rgba(17, 17, 17, 0.97);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 16px 20px;
  }
  .cookie-inner {
    max-width: 980px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: center;
  }
  @media (min-width: 640px) {
    .cookie-inner {
      flex-direction: row;
      justify-content: space-between;
    }
  }
  .cookie-text {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
    max-width: 56ch;
  }
  .cookie-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }
  .cookie-btn {
    padding: 9px 18px;
    font-size: 13px;
    font-weight: 700;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.2s, transform 0.15s;
  }
  .cookie-btn--reject {
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }
  .cookie-btn--reject:hover {
    background: rgba(255, 255, 255, 0.12);
  }
  .cookie-btn--accept {
    background: var(--brand);
    color: #fff;
  }
  .cookie-btn--accept:hover {
    background: var(--brand-d);
    transform: translateY(-1px);
  }

  /* Scroll to top */
  .scroll-top-btn {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 100;
    width: 48px;
    height: 48px;
    background: var(--brand);
    border: 0;
    border-radius: 50%;
    display: grid;
    place-items: center;
    color: #fff;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(255, 123, 3, 0.4);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: opacity 0.25s, transform 0.25s, visibility 0.25s, background 0.2s;
  }
  .scroll-top-btn.is-visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .scroll-top-btn:hover {
    background: var(--brand-d);
  }
  .scroll-top-btn.is-visible:hover {
    transform: translateY(-2px);
  }
</style>
