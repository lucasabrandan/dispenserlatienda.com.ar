<script>
  const waNumber = document.getElementById("equipos")?.dataset.waNumber || "5491166082608";
  const WA_BASE = "https://wa.me/" + waNumber + "?text=";

  document.querySelectorAll<HTMLElement>(".card-equipo").forEach((card) => {
    // Toggle Botellón / Red de agua
    const toggleBtns = card.querySelectorAll<HTMLButtonElement>(".toggle-variant");
    if (toggleBtns.length) {
      const infoBlock = card.querySelector<HTMLElement>(".info-red");
      const ctaBtn = card.querySelector<HTMLAnchorElement>(".btn-cotizar");
      const galeria = card.querySelector<HTMLElement>(".galeria");
      const mainImg = galeria?.querySelector<HTMLImageElement>("[data-galeria-main]");
      const thumbs = galeria?.querySelectorAll<HTMLButtonElement>(".galeria-thumb");

      toggleBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          const variant = btn.dataset.variant;
          const waMsg = btn.dataset.waMsg;

          toggleBtns.forEach((b) => {
            const active = b === btn;
            b.classList.toggle("active", active);
            b.setAttribute("aria-selected", String(active));
          });

          if (infoBlock) {
            infoBlock.classList.toggle("is-hidden", variant !== "red");
          }

          if (ctaBtn && waMsg) {
            ctaBtn.href = WA_BASE + encodeURIComponent(waMsg);
          }

          // Swap de imágenes según variante
          if (galeria && mainImg && thumbs) {
            const dataKey = variant === "red" ? "imagenesRed" : "imagenesBotellon";
            const raw = galeria.dataset[dataKey];
            if (raw) {
              try {
                const nuevasImgs = JSON.parse(raw) as string[];
                if (nuevasImgs.length > 0) {
                  mainImg.src = nuevasImgs[0];
                  thumbs.forEach((thumb, idx) => {
                    const newImg = nuevasImgs[idx];
                    if (newImg) {
                      const thumbImg = thumb.querySelector<HTMLImageElement>("img");
                      if (thumbImg) thumbImg.src = newImg;
                      thumb.dataset.image = newImg;
                      const isFirst = idx === 0;
                      thumb.classList.toggle("active", isFirst);
                      thumb.setAttribute("aria-selected", String(isFirst));
                    }
                  });
                }
              } catch (e) {
                // Si fallara el parse, no rompemos el toggle
              }
            }
          }
        });
      });
    }

    // Galería de imágenes
    const galeria = card.querySelector<HTMLElement>(".galeria");
    if (galeria) {
      const mainImg = galeria.querySelector<HTMLImageElement>("[data-galeria-main]");
      const thumbs = galeria.querySelectorAll<HTMLButtonElement>(".galeria-thumb");

      thumbs.forEach((thumb) => {
        thumb.addEventListener("click", () => {
          const newSrc = thumb.dataset.image;
          if (!mainImg || !newSrc) return;

          mainImg.src = newSrc;

          thumbs.forEach((t) => {
            const active = t === thumb;
            t.classList.toggle("active", active);
            t.setAttribute("aria-selected", String(active));
          });
        });
      });
    }
  });

  // Toggle "Ver detalles" en cards de los grupos (mobile)
  document.querySelectorAll<HTMLElement>(".grupo-grid > .card-equipo").forEach((card) => {
    const verMasBtn = card.querySelector<HTMLButtonElement>(".ver-mas-btn");
    const verMasText = verMasBtn?.querySelector<HTMLElement>(".ver-mas-text");
    if (!verMasBtn) return;

    verMasBtn.addEventListener("click", () => {
      const isExpanded = card.classList.toggle("expanded");
      verMasBtn.setAttribute("aria-expanded", String(isExpanded));
      if (verMasText) {
        verMasText.textContent = isExpanded ? "Ocultar detalles" : "Ver detalles";
      }
    });
  });

  // Grupos de equipos (Línea Classic / Línea Pro) — carrusel mobile con dots
  document.querySelectorAll<HTMLElement>(".grupo-equipos").forEach((grupo) => {
    const grid = grupo.querySelector<HTMLElement>(".grupo-grid");
    const dots = grupo.querySelectorAll<HTMLElement>(".grupo-dots .dot");
    if (!grid || dots.length === 0) return;

    const isMobile = () => window.matchMedia("(max-width: 979px)").matches;

    // Update dot indicator según scroll
    const updateDots = () => {
      if (!isMobile()) return;
      const cards = grid.querySelectorAll<HTMLElement>(".card-equipo");
      if (cards.length === 0) return;
      const cardWidth = (cards[0] as HTMLElement).offsetWidth + 14; // 14px = gap
      const idx = Math.round(grid.scrollLeft / cardWidth);
      const clamped = Math.max(0, Math.min(dots.length - 1, idx));
      dots.forEach((d, i) => d.classList.toggle("active", i === clamped));
    };
    grid.addEventListener("scroll", updateDots, { passive: true });
    updateDots();

    // Preview-scroll inicial al entrar al viewport (solo mobile)
    let didPreview = false;
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting && !didPreview && isMobile()) {
          didPreview = true;
          setTimeout(() => {
            grid.scrollTo({ left: grid.clientWidth * 0.35, behavior: "smooth" });
            setTimeout(() => {
              grid.scrollTo({ left: 0, behavior: "smooth" });
            }, 900);
          }, 700);
        }
      });
    }, { threshold: 0.3 });
    io.observe(grupo);
  });

  // Banner restricciones collapsible en mobile
  const banner = document.querySelector<HTMLElement>(".info-banner");
  if (banner) {
    const title = banner.querySelector<HTMLElement>(".info-banner-title");
    const mq = window.matchMedia("(max-width: 639px)");

    const applyMobileState = (isMobile: boolean) => {
      if (isMobile) banner.classList.add("is-collapsed");
      else banner.classList.remove("is-collapsed");
    };

    applyMobileState(mq.matches);
    mq.addEventListener("change", (e) => applyMobileState(e.matches));

    if (title) {
      title.addEventListener("click", () => {
        // Solo togglea si está en mobile
        if (window.matchMedia("(max-width: 639px)").matches) {
          banner.classList.toggle("is-collapsed");
        }
      });
    }
  }

  // Protección de imágenes — disuade copia/descarga
  const equiposSection = document.getElementById("equipos");
  if (equiposSection) {
    equiposSection.addEventListener("contextmenu", (e) => {
      const target = e.target as HTMLElement;
      if (target.tagName === "IMG" || target.classList.contains("galeria-overlay")) {
        e.preventDefault();
      }
    });
    equiposSection.addEventListener("dragstart", (e) => {
      const target = e.target as HTMLElement;
      if (target.tagName === "IMG") {
        e.preventDefault();
      }
    });
  }
</script>

<style is:global>
  /* ===== Sección ===== */
  .equipos {
    background: var(--surface);
    padding: 72px 24px 80px;
    border-top: 1px solid #eee;
  }

  /* Header */
  .sec-header {
    text-align: center;
    margin-bottom: 48px;
  }
  .eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brand);
    margin-bottom: 12px;
  }
  h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 900;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 14px;
  }
  .sec-sub {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.6;
    max-width: 580px;
    margin: 0 auto;
  }

  /* ===== Banner restricciones ===== */
  .info-banner {
    max-width: 1200px;
    margin: 0 auto 32px;
    background: #FFF8EC;
    border: 1px solid #FFE6B8;
    border-radius: 16px;
    padding: 18px 22px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .info-banner-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 700;
    color: #92400e;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .info-banner-title svg { color: #d97706; flex-shrink: 0; }

  /* Collapsible behavior — solo activo en mobile via JS class */
  .info-banner.is-collapsed .info-banner-list { display: none; }
  @media (max-width: 639px) {
    .info-banner-title {
      cursor: pointer;
      user-select: none;
      justify-content: space-between;
    }
    .info-banner-title::after {
      content: "▾";
      color: #d97706;
      font-size: 11px;
      transition: transform 0.2s;
    }
    .info-banner:not(.is-collapsed) .info-banner-title::after {
      transform: rotate(180deg);
    }
  }
  .info-banner-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
  }
  @media (min-width: 720px) {
    .info-banner-list { grid-template-columns: repeat(3, 1fr); gap: 18px; }
  }
  .info-banner-list li {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 13px;
    color: #5b3a00;
    line-height: 1.5;
  }
  .info-banner-list li svg {
    color: #d97706;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .info-banner-list li strong { color: #1a1a1a; }

  /* ===== Galería ===== */
  .galeria {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .galeria-main {
    position: relative;
    flex: 1;
    overflow: hidden;
  }
  .galeria-img {
    user-select: none;
    -webkit-user-drag: none;
    -webkit-touch-callout: none;
    pointer-events: none;
  }
  /* Capa transparente que intercepta clicks/contextmenu sobre la imagen */
  .galeria-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: transparent;
    cursor: default;
  }
  .galeria-thumbs {
    display: flex;
    justify-content: center;
    gap: 6px;
    padding: 10px 14px;
    background: #fafafa;
    border-top: 1px solid var(--border);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .galeria-thumbs::-webkit-scrollbar { display: none; }
  .galeria-thumb {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    background: #fff;
    border: 2px solid transparent;
    border-radius: 8px;
    padding: 4px;
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.15s, transform 0.15s;
  }
  .galeria-thumb:hover {
    border-color: rgba(255,123,3,0.4);
    transform: translateY(-1px);
  }
  .galeria-thumb.active {
    border-color: var(--brand);
    background: #fff;
  }
  .galeria-thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    user-select: none;
    -webkit-user-drag: none;
    -webkit-touch-callout: none;
    pointer-events: none;
  }
  /* ===== Grupo Equipos (línea Classic / Pro) ===== */
  .grupo-equipos {
    max-width: 1200px;
    margin: 0 auto 36px;
  }
  .grupo-equipos:last-of-type { margin-bottom: 0; }

  .grupo-titulo {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.01em;
    margin-bottom: 6px;
  }

  .swipe-hint {
    display: none;
  }
  @media (max-width: 979px) {
    .swipe-hint {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 11.5px;
      font-weight: 600;
      color: var(--brand);
      margin-bottom: 12px;
      animation: equipo-swipe-pulse 2s ease-in-out infinite;
    }
  }
  @keyframes equipo-swipe-pulse {
    0%, 100% { transform: translateX(0); opacity: 0.85; }
    50% { transform: translateX(5px); opacity: 1; }
  }

  /* Mobile: carrusel horizontal */
  .grupo-grid {
    display: flex;
    flex-direction: row;
    gap: 14px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    margin: 0 -24px;
    padding: 4px 24px 8px;
  }
  .grupo-grid::-webkit-scrollbar { display: none; }
  .grupo-grid > .card-equipo {
    flex: 0 0 auto;
    width: 80%;
    min-width: 0;
    scroll-snap-align: center;
  }
  @media (min-width: 480px) {
    .grupo-grid > .card-equipo { width: 60%; }
  }
  @media (min-width: 720px) {
    .grupo-grid > .card-equipo { width: 42%; }
  }

  /* Desktop: grid 3 cols */
  @media (min-width: 980px) {
    .grupo-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin: 0;
      padding: 0;
      overflow: visible;
    }
    .grupo-grid > .card-equipo {
      width: auto;
    }
  }

  /* Dots indicators — solo mobile/tablet */
  .grupo-dots {
    display: flex;
    gap: 7px;
    justify-content: center;
    margin-top: 14px;
  }
  .grupo-dots .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #d1d5db;
    transition: background 0.25s, width 0.25s, border-radius 0.25s;
