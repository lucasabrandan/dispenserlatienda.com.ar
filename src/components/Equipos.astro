---
import EquipoCard from "./EquipoCard.astro";

import { PHONE, COBERTURA } from "../config/site";
const WA = (text: string) => `https://wa.me/${PHONE.raw}?text=${encodeURIComponent(text + " 🛒")}`;

type Spec = { k: string; v: string };

type Producto = {
  id: string;
  nombre: string;
  subtitulo: string;
  descripcion: string;
  imagenes: string[];           // Imágenes versión botellón (default si hasToggle)
  imagenesRed?: string[];       // Imágenes versión a red de agua (opcional)
  imagenAlt: string;
  bullets: string[];
  specs: Spec[];
  hasToggle: boolean;
  badge?: string;
  infoFijo?: boolean;
  origen: "nacional" | "premium";
  linea?: "classic" | "pro";    // para agrupar en mobile carruseles
  waBotellon?: string;
  waRed?: string;
  waUnico?: string;
};

const dispensers: Producto[] = [
  {
    id: "classic-fc",
    nombre: "Classic FC",
    subtitulo: "Dispenser frío/calor de pie · botellón de 20 L",
    descripcion: "Agua fría a 5°C y caliente a 85°C en cualquier momento. Compresor real para enfriado eficiente, ideal para oficinas, comercios y hogares.",
    imagenes: ["/equipos/DIS-BLANCO-FRENTE-BIDON.webp", "/equipos/DIS-BLANCO-LATERAL-BIDON.webp"],
    imagenesRed: ["/equipos/DIS-BLANCO-FRENTE.webp", "/equipos/DIS-BLANCO-LATERAL.webp"],
    imagenAlt: "Dispenser de agua frío calor blanco para botellón de 20 litros",
    bullets: [
      "Compresor real (no termoeléctrico) — enfría 10 L/h a 5°C",
      "Agua caliente lista al instante — 8 L/h a 85°C, ideal para mate y café",
      "Industria argentina · 12 meses de garantía de fábrica",
      "Bandeja antigoteo removible para limpieza fácil",
    ],
    specs: [
      { k: "Tipo de carga", v: "Botellón superior 20 L" },
      { k: "Canillas", v: "2 (fría + caliente)" },
      { k: "Capacidad fría", v: "10 L/h a 5°C" },
      { k: "Capacidad caliente", v: "8 L/h a 85°C" },
      { k: "Sistema de frío", v: "Compresor con protector térmico" },
      { k: "Voltaje", v: "220V" },
      { k: "Medidas", v: "93 × 31 × 29 cm" },
      { k: "Peso", v: "11 kg" },
      { k: "Color", v: "Blanco" },
      { k: "Garantía", v: "12 meses de fábrica" },
    ],
    hasToggle: true,
    origen: "nacional",
    linea: "classic",
    waBotellon: "Hola, quiero cotizar el dispenser Classic FC.",
    waRed: "Hola, quiero cotizar el dispenser Classic FC versión a red de agua, con filtro y kit de instalación. Estoy en [zona].",
  },
  {
    id: "compact",
    nombre: "Compact",
    subtitulo: "Dispenser frío/calor de mesa · botellón de 20 L",
    descripcion: "Toda la potencia de un dispenser de pie en formato compacto. Ideal para oficinas chicas, recepciones, kitchenettes y hogares con poco espacio.",
    imagenes: ["/equipos/DIS-MINI-FRENTE-BIDON.webp", "/equipos/DIS-MINI-LATERAL-BIDON.webp"],
    imagenesRed: ["/equipos/DIS-MINI-FRENTE.webp", "/equipos/DIS-MINI-LATERAL.webp"],
    imagenAlt: "Dispenser de agua frío calor compacto de mesa para botellón",
    bullets: [
      "Mayor rendimiento de frío que el de pie — 12 L/h a 5°C",
      "Agua caliente para mate — 8 L/h a 85°C",
      "Industria argentina · 12 meses de garantía de fábrica",
      "Portavasos integrados y canillas antigoteo",
    ],
    specs: [
      { k: "Tipo", v: "De mesa para botellón superior 20 L" },
      { k: "Canillas", v: "2 antigoteo (fría + caliente)" },
      { k: "Capacidad fría", v: "12 L/h a 5°C" },
      { k: "Capacidad caliente", v: "8 L/h a 85°C" },
      { k: "Consumo", v: "550W" },
      { k: "Voltaje", v: "220V" },
      { k: "Medidas", v: "49 × 31 × 29 cm" },
      { k: "Peso", v: "11 kg" },
      { k: "Color", v: "Blanco" },
      { k: "Garantía", v: "12 meses de fábrica" },
    ],
    hasToggle: true,
    origen: "nacional",
    linea: "classic",
    waBotellon: "Hola, quiero cotizar el dispenser Compact.",
    waRed: "Hola, quiero cotizar el dispenser Compact versión a red de agua, con filtro y kit de instalación. Estoy en [zona].",
  },
  {
    id: "classic-office",
    nombre: "Classic Office",
    subtitulo: "Dispenser frío/calor monocasco · indicador LED",
    descripcion: "Diseño monocasco con cuerpo de una sola pieza y look limpio para oficina. Indicador LED que te avisa cuando el agua está lista. Pensado para oficinas y espacios donde el equipo se ve.",
    imagenes: ["/equipos/DIS-BN-FRENTE.webp", "/equipos/DIS-BN-LATERAL.webp"],
    imagenAlt: "Dispenser de agua frío calor monocasco con indicador LED",
    bullets: [
      "Diseño monocasco — cuerpo de una sola pieza, líneas limpias",
      "Luz LED indicadora de temperatura",
      "Marca líder con respaldo de fábrica · 12 meses de garantía",
      "Frío y caliente con regulación precisa",
    ],
    specs: [
      { k: "Tipo de carga", v: "Botellón superior 20 L" },
      { k: "Canillas", v: "Frío + caliente" },
      { k: "Indicador", v: "Luz LED" },
      { k: "Voltaje", v: "220V" },
      { k: "Peso", v: "10 kg" },
      { k: "Color", v: "Blanco con detalles negros" },
      { k: "Garantía", v: "12 meses de fábrica" },
    ],
    hasToggle: true,
    origen: "premium",
    linea: "classic",
    waBotellon: "Hola, quiero cotizar el dispenser Classic Office.",
    waRed: "Hola, quiero cotizar el dispenser Classic Office versión a red de agua, con filtro y kit de instalación. Estoy en [zona].",
  },
  {
    id: "pro-trio",
    nombre: "Pro Trio",
    subtitulo: "Dispenser platinado · 3 temperaturas · botellón 20 L",
    descripcion: "Frío, ambiente y caliente en un solo equipo. Para quien quiere agua a temperatura natural sin esperar y mantener la opción de fría o caliente al instante.",
    imagenes: ["/equipos/DIS-PLAT3C-FRENTE.webp", "/equipos/DIS-PLAT3C-LATERAL.webp"],
    imagenAlt: "Dispenser platinado de 3 temperaturas con LED",
    bullets: [
      "3 temperaturas reales — fría 5°C · ambiente · caliente 85°C",
      "Iluminación LED integrada · acabado platinado premium",
      "Marca líder con respaldo de fábrica · 12 meses de garantía",
      "Estructura de acero con plásticos de alta calidad",
    ],
    specs: [
      { k: "Tipo de carga", v: "Botellón superior 20 L" },
      { k: "Canillas", v: "3 (fría + ambiente + caliente)" },
      { k: "Capacidad fría", v: "5 L/h a 5°C (85W)" },
      { k: "Capacidad caliente", v: "8 L/h a 85°C (500W)" },
      { k: "Voltaje", v: "220-240V · 50/60 Hz" },
      { k: "Medidas", v: "90 × 32 × 36 cm" },
      { k: "Color", v: "Plata / Platinum" },
      { k: "Materiales", v: "Acero + plásticos premium" },
      { k: "Garantía", v: "12 meses de fábrica" },
    ],
    hasToggle: true,
    origen: "premium",
    linea: "pro",
    waBotellon: "Hola, quiero cotizar el dispenser Pro Trio.",
    waRed: "Hola, quiero cotizar el dispenser Pro Trio versión a red de agua, con filtro y kit de instalación. Estoy en [zona].",
  },
  {
    id: "pro-ice",
    nombre: "Pro Ice",
    subtitulo: "Top de gama · 3 temperaturas + fabricadora de hielo",
    descripcion: "El equipo más completo del catálogo. Frío, ambiente, caliente y hasta 13 kg de hielo por día integrados en un solo dispenser con panel táctil. Para oficinas premium, eventos corporativos y espacios gourmet.",
    imagenes: ["/equipos/DISP-PLAT3C-HIELO-FRENTE.webp", "/equipos/DISP-PLAT3C-HIELO-LATERAL.webp"],
    imagenAlt: "Dispenser platinado top de gama con fabricadora de hielo y panel táctil",
    bullets: [
      "Fabricadora de hielo integrada — hasta 13 kg/día sin freezer aparte",
      "3 temperaturas + agua caliente para mate (5 L/h)",
      "Panel táctil digital + bloqueo infantil en agua caliente",
      "Marca líder con respaldo de fábrica · 12 meses de garantía",
    ],
    specs: [
      { k: "Tipo de carga", v: "Botellón superior 20 L" },
      { k: "Canillas", v: "3 (fría + ambiente + caliente)" },
      { k: "Hielo", v: "Hasta 13 kg/día" },
      { k: "Caliente", v: "Hasta 5 L/h" },
      { k: "Panel", v: "Táctil digital" },
      { k: "Seguridad", v: "Bloqueo infantil en canilla caliente" },
      { k: "Voltaje", v: "220V" },
      { k: "Color", v: "Plata / Platinum" },
      { k: "Garantía", v: "12 meses de fábrica" },
    ],
    hasToggle: true,
    badge: "Bajo pedido",
    origen: "premium",
    linea: "pro",
    waBotellon: "Hola, quiero consultar disponibilidad del dispenser Pro Ice.",
    waRed: "Hola, quiero consultar disponibilidad del dispenser Pro Ice versión a red de agua, con filtro y kit de instalación. Estoy en [zona].",
  },
  {
    id: "pro",
    nombre: "Pro",
    subtitulo: "Dispenser platinado de pie · empuja vaso · botellón 20 L",
    descripcion: "Diseño premium en color plata para espacios que cuidan la imagen: oficinas ejecutivas, recepciones corporativas, locales gastronómicos.",
    imagenes: ["/equipos/DIS-PLAT-FRENTE.webp", "/equipos/DIS-PLAT-LATERAL.webp", "/equipos/DIS-PLAT-PPLANO.webp"],
    imagenAlt: "Dispenser platinado de pie con sistema empuja vaso",
    bullets: [
      "Sistema empuja-vaso — apoyás el vaso y sale agua, sin tocar canilla",
      "Acabado platinado elegante",
      "Marca líder con respaldo de fábrica · 12 meses de garantía",
      "Frío y caliente con compresor real",
    ],
    specs: [
      { k: "Tipo de carga", v: "Botellón superior 20 L" },
      { k: "Sistema", v: "Empuja-vaso (frío + caliente)" },
      { k: "Voltaje", v: "220V" },
      { k: "Color", v: "Plata / Platinum" },
      { k: "Garantía", v: "12 meses de fábrica" },
    ],
    hasToggle: true,
    origen: "premium",
    linea: "pro",
    waBotellon: "Hola, quiero cotizar el dispenser Pro.",
    waRed: "Hola, quiero cotizar el dispenser Pro versión a red de agua, con filtro y kit de instalación. Estoy en [zona].",
  },
];

// Agrupación por líneas para mobile carrusel + desktop grid
const lineaClassic = dispensers.filter((p) => p.linea === "classic");
const lineaPro = ["pro", "pro-trio", "pro-ice"]
  .map((id) => dispensers.find((p) => p.id === id))
  .filter((p): p is Producto => p !== undefined);

const bebedero: Producto = {
  id: "bebedero",
  nombre: "Bebedero Inox",
  subtitulo: "Bebedero industrial de acero inoxidable · conexión a red",
  descripcion: "Equipo industrial de alta resistencia para escuelas, gimnasios, fábricas, talleres y oficinas con alto tráfico. Conexión directa a red de agua, sin botellones.",
  imagenes: ["/equipos/BEBEDERO.webp", "/equipos/BEBEDERO-ARRIBA.webp", "/equipos/BEBEDERO-ATRAS.webp"],
  imagenAlt: "Bebedero industrial de acero inoxidable para escuelas y gimnasios",
  bullets: [
    "Acero inoxidable — antivandálico, fácil limpieza, larga vida útil",
    "Compresor de 1/6 HP para uso intensivo continuo",
    "2 versiones disponibles — 40 L/h o 80 L/h según consumo",
    "Industria argentina · 12 meses de garantía de fábrica",
  ],
  specs: [
    { k: "Tipo", v: "De pie · conexión a red de agua" },
    { k: "Material", v: "Acero inoxidable" },
    { k: "Capacidad", v: "40 L/h o 80 L/h" },
    { k: "Sistema de frío", v: "Compresor 1/6 HP" },
    { k: "Medidas", v: "97 × 34 × 33 cm" },
    { k: "Peso", v: "30 kg" },
    { k: "Voltaje", v: "220V" },
    { k: "Garantía", v: "12 meses de fábrica" },
    { k: "Aplicaciones", v: "Escuelas · gimnasios · fábricas · oficinas" },
  ],
  hasToggle: false,
  infoFijo: true,
  badge: "Bajo pedido",
  origen: "nacional",
  waUnico: "Hola, quiero consultar el bebedero industrial inox. Estoy en [zona].",
};

const filtro: Producto = {
  id: "filtro-ellen",
  nombre: "Filtro purificador Ellen MP 80",
  subtitulo: "Purificador de mesada · Aprobado ANMAT · Industria nacional",
  descripcion: "Agua segura directo de tu canilla. Se conecta con un bypass — usás tu canilla como siempre (fría o caliente) y cuando querés agua filtrada, sale por el pico del purificador. Sin perforar mesada, sin instalación compleja.",
  imagenes: ["/equipos/FILTRO-0.webp", "/equipos/FILTRO-1.webp", "/equipos/FILTRO-2.webp"],
  imagenAlt: "Filtro purificador de agua Ellen MP 80 aprobado por ANMAT",
  bullets: [
    "3 años de vida útil · 36.000 litros filtrados",
    "Aprobado por ANMAT y fabricado bajo norma IRAM 27300",
    "Carbón activado con iones de plata — bactericida natural",
    "Industria argentina (Italsur SA)",
  ],
  specs: [
    { k: "Tipo", v: "Purificador de mesada" },
    { k: "Instalación", v: "Bypass a canilla existente" },
    { k: "Vida útil", v: "3 años · 36.000 litros" },
    { k: "Caudal", v: "80 L/h" },
    { k: "Componentes", v: "Carbón activado + iones de plata + membranas polipropileno" },
    { k: "Pico", v: "Giratorio de movimiento soft" },
    { k: "Reposición", v: "Equipo completo cada 3 años" },
    { k: "Certificaciones", v: "ANMAT · INAL · IRAM 27300" },
    { k: "Origen", v: "Industria argentina (Italsur SA)" },
  ],
  hasToggle: false,
  origen: "nacional",
  waUnico: "Hola, quiero cotizar el purificador Ellen MP 80.",
};

const eliminaFiltro = [
  "Cloro, mal olor y mal sabor",
  "Trihalometanos (derivados del cloro)",
  "Sedimentos, arenillas, tierra y partículas",
  "Algas, moho y turbiedad",
  "Metales pesados: plomo, óxidos, cobre y cadmio",
];

const MAIL_CORP_SUBJECT = encodeURIComponent("Solicitud de cotización — Alquiler corporativo de equipos");
const MAIL_CORP_BODY = encodeURIComponent(
  "Hola, me comunico desde la web para consultar por el alquiler corporativo de equipos.\n\n" +
  "Empresa / Razón social: \n" +
  "Cantidad de equipos a alquilar (mínimo 5): \n" +
  "Dirección de instalación: \n" +
  "Cantidad aproximada de personas en la oficina: \n" +
  "Información adicional: \n\n" +
  "Quedo a la espera, gracias."
);
const MAIL_CORPORATIVO = `mailto:info@dispenserlatienda.com.ar?subject=${MAIL_CORP_SUBJECT}&body=${MAIL_CORP_BODY}`;
---

<section class="equipos" id="equipos" data-wa-number={PHONE.raw}>

  <div class="sec-header">
    <span class="eyebrow">Equipos y filtros</span>
    <h2>Dispensers, bebederos<br>y purificadores</h2>
    <p class="sec-sub">
      Equipamiento profesional con respaldo de marca líder y garantía de fábrica.
      Para oficinas, comercios, hogares y empresas.
    </p>
  </div>

  <div class="info-banner reveal" role="note" aria-label="Información importante de compra">
    <div class="info-banner-title">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      Antes de comprar — información importante
    </div>
    <ul class="info-banner-list" role="list">
      <li>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        <span>Despachamos solo en <strong>{COBERTURA.despacho}</strong></span>
      </li>
      <li>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <line x1="3" y1="9" x2="21" y2="9"/>
        </svg>
        <span><strong>Sin local físico</strong> — solo envío a domicilio</span>
      </li>
      <li>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="1" y="3" width="15" height="13"/>
          <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
          <circle cx="5.5" cy="18.5" r="2.5"/>
          <circle cx="18.5" cy="18.5" r="2.5"/>
        </svg>
        <span>El <strong>costo de envío</strong> se cotiza aparte según zona</span>
      </li>
    </ul>
  </div>

  <!-- Grupo Línea Classic -->
  <div class="grupo-equipos reveal">
    <h3 class="grupo-titulo">Línea Classic</h3>
    <p class="swipe-hint" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
      Deslizá para ver más
    </p>
    <div class="grupo-grid" id="grupo-classic-grid">
      {lineaClassic.map((p) => <EquipoCard producto={p} />)}
    </div>
    <div class="grupo-dots" data-target="grupo-classic-grid" aria-hidden="true">
      {lineaClassic.map((_, i) => <span class="dot" data-dot-idx={i} />)}
    </div>
  </div>

  <!-- Grupo Línea Pro -->
  <div class="grupo-equipos reveal">
    <h3 class="grupo-titulo">Línea Pro</h3>
    <p class="swipe-hint" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
      Deslizá para ver más
    </p>
    <div class="grupo-grid" id="grupo-pro-grid">
      {lineaPro.map((p) => <EquipoCard producto={p} />)}
    </div>
    <div class="grupo-dots" data-target="grupo-pro-grid" aria-hidden="true">
      {lineaPro.map((_, i) => <span class="dot" data-dot-idx={i} />)}
    </div>
  </div>

  <!-- Bebedero industrial — card horizontal destacada -->
  <div class="hero-wrap">
    <article class="card-equipo card-hero reveal" data-product-id={bebedero.id}>
      {bebedero.badge && <span class="badge">{bebedero.badge}</span>}

      <div class="card-imagen galeria">
        <div class="galeria-main">
          <img
            src={bebedero.imagenes[0]}
            alt={bebedero.imagenAlt}
            loading="lazy"
            width="400"
            height="500"
            draggable="false"
            class="galeria-img"
            data-galeria-main
          />
          <div class="galeria-overlay" aria-hidden="true"></div>
        </div>
        {bebedero.imagenes.length > 1 && (
          <div class="galeria-thumbs" role="tablist" aria-label="Otras vistas del producto">
            {bebedero.imagenes.map((img, idx) => (
              <button
                type="button"
                class:list={["galeria-thumb", { active: idx === 0 }]}
                data-image={img}
                data-image-idx={idx}
                aria-label={`Ver imagen ${idx + 1}`}
                role="tab"
                aria-selected={idx === 0 ? "true" : "false"}
              >
                <img
                  src={img}
                  alt=""
                  loading="lazy"
                  draggable="false"
                />
              </button>
            ))}
          </div>
        )}
      </div>

      <div class="card-body">
        <h3 class="card-title">{bebedero.nombre}</h3>
        <p class="card-subtitle">{bebedero.subtitulo}</p>

        <div class="info-red">
          <div class="info-red-title">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 2.69 5.66 9.03a8 8 0 1 0 12.68 0z"/>
            </svg>
            Conexión directa a la red
          </div>
          <p class="info-red-text">Esta versión requiere:</p>
          <ul class="info-red-list">
            <li>Filtro previo (cotiza aparte)</li>
            <li>Kit de conexión a cañería</li>
          </ul>
          <p class="info-red-zone">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            Instalación a domicilio disponible en <strong>{COBERTURA.despacho}</strong>
          </p>
        </div>

        <p class="card-desc">{bebedero.descripcion}</p>

        <ul class="bullets" role="list">
          {bebedero.bullets.map((b) => (
            <li>{b}</li>
          ))}
        </ul>

        <a
          href={WA(bebedero.waUnico!)}
          class="btn-cotizar"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
