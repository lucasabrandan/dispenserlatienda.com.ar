---
import { WA, COBERTURA } from "../config/site";

const grupos = [
  {
    label: "Problemas con tu dispenser",
    iconColor: "orange",
    icon: `<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>`,
    items: [
      {
        q: "El agua tiene gusto u olor extraño, ¿qué puede ser?",
        a: "Casi siempre es el filtro de carbón activado saturado o el circuito interno que necesita limpieza. Con un mantenimiento anual (limpieza + desinfección + cambio de filtro) queda resuelto.",
        cta: "Coordinar visita",
        msg: "Hola, el agua de mi dispenser tiene un gusto/olor extraño. Quiero coordinar una visita.",
      },
      {
        q: "Sentí una descarga eléctrica o da corriente, ¿qué hago?",
        a: "Desenchufalo de inmediato y no lo uses hasta que lo revise un técnico. Puede ser humedad interna, falla de aislación o cableado desgastado.",
        cta: "Solicitar revisión urgente",
        msg: "Hola, mi dispenser me está dando corriente. Necesito una revisión urgente.",
      },
      {
        q: "Salió olor a quemado o humo, ¿qué hago?",
        a: "Desenchufalo de inmediato y no lo vuelvas a encender. Puede ser sobrecalentamiento del compresor o una falla eléctrica interna. Hacemos diagnóstico completo antes de cualquier intervención.",
        cta: "Pedir diagnóstico",
        msg: "Hola, mi dispenser largó olor a quemado. Necesito un diagnóstico urgente.",
      },
      {
        q: "Mi dispenser pierde agua, ¿por qué pasa?",
        a: "Puede ser una unión mal sellada, el flotante interno o una pérdida del botellón. Si viene del interior del equipo, necesita revisión técnica.",
        cta: "Agendar revisión",
        msg: "Hola, mi dispenser está perdiendo agua. Quiero agendar una revisión.",
      },
      {
        q: "No enfría, no calienta o funciona a veces sí y a veces no",
        a: "Para el frío: verificá que la parrilla trasera tenga al menos 10 cm de ventilación. Para el calor: confirmá que el sistema esté activado. Si persiste, puede ser falla del compresor, la resistencia o el termostato.",
        cta: "Consultar por WhatsApp",
        msg: "Hola, mi dispenser tiene problemas para enfriar/calentar. Quiero consultarles.",
      },
      {
        q: "Ya revisé todo y el problema sigue, ¿qué hago?",
        a: "Cuando el problema es recurrente o no tiene explicación simple, lo mejor es un mantenimiento integral: limpieza interna, revisión eléctrica, cambio de filtro y prueba de funcionamiento.",
        cta: "Contactar por WhatsApp",
        msg: "Hola, mi dispenser sigue con problemas. Quiero coordinar un mantenimiento integral.",
      },
    ],
  },
  {
    label: "Sobre el servicio",
    iconColor: "blue",
    icon: `<circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>`,
    items: [
      {
        q: "¿En qué zonas trabajan?",
        html: `<p><strong>Cobertura principal:</strong> toda Capital Federal (CABA), todos los barrios.</p>
<p><strong>También llegamos</strong> al Gran Buenos Aires: Avellaneda, Lanús, Lomas de Zamora, Banfield, Temperley, Bernal y más. Pasanos tu dirección y te confirmamos.</p>
<p><strong>Empresas con varios equipos:</strong> ampliamos la cobertura a todo el GBA. Consultanos por tu zona.</p>`,
        cta: "Consultar por mi zona",
        msg: "Hola, quiero saber si llegan a mi zona.",
      },
      {
        q: "¿Cuánto tarda en llegar el técnico?",
        a: "Coordinamos la visita en 24 a 48 horas según la demanda. En casos urgentes hacemos lo posible por acelerar.",
      },
      {
        q: "¿Cada cuánto conviene hacer el mantenimiento?",
        a: "Una vez al año es suficiente para mantener el agua limpia y el equipo en buen estado. Te recomendamos no esperar más para evitar problemas mayores.",
      },
      {
        q: "¿Cómo se pide el servicio?",
        a: "Todo por WhatsApp. Nos contás qué necesitás, si es reparación nos mandás fotos del equipo, te pasamos un estimativo y coordinamos día y horario.",
      },
      {
        q: "¿Atienden los sábados?",
        a: "Sí, atendemos los sábados. Escribinos por WhatsApp y coordinamos según disponibilidad.",
      },
      {
        q: "¿Emiten factura? ¿Tienen garantía?",
        a: "Sí a los dos. Emitimos factura por todos los trabajos y damos 90 días de garantía sobre reparaciones y limpiezas.",
      },
    ],
  },
];

// Schema.org FAQPage — todas las preguntas en un solo bloque
const allFaqs = grupos.flatMap(g => g.items);
const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": allFaqs.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a ?? item.html?.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim(),
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

<section class="faq" id="faq">
  <div class="inner">

    <div class="header">
      <span class="eyebrow">Preguntas frecuentes</span>
      <h2>Lo que más<br>nos preguntan</h2>
      <p class="sec-sub">Preparadas para el 90% de las consultas que recibimos.</p>
    </div>

    <p class="swipe-hint" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
      Deslizá para ver más
    </p>

    <div class="faq-groups" id="faq-groups">
    {grupos.map((grupo) => (
      <div class="faq-group">

        <div class="group-label">
          <div class={`group-icon ${grupo.iconColor}`} aria-hidden="true">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.2"
                 stroke-linecap="round" stroke-linejoin="round"
                 set:html={grupo.icon} />
          </div>
          <span class="group-title">{grupo.label}</span>
        </div>

        <div class="faq-list">
          {grupo.items.map((item) => (
            <details class="faq-item" name={`faq-${grupo.iconColor}`}>
              <summary class="faq-q">
                <span>{item.q}</span>
                <span class="chevron" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                       stroke="currentColor" stroke-width="2.5"
                       stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </span>
              </summary>
              <div class="faq-body">
                {item.html ? <div class="faq-html" set:html={item.html} /> : <p>{item.a}</p>}
                {item.cta && (
                  <a
                    href={WA.base + encodeURIComponent(item.msg + " ❓")}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="faq-btn"
                    data-wa-event="faq"
                  >
                    <svg width="13" height="13" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
                      <path d="M19.11 17.25c-.28-.14-1.64-.81-1.89-.9s-.44-.14-.62.14c-.18.28-.71.9-.87 1.08-.16.18-.32.2-.6.07-.28-.14-1.2-.44-2.28-1.4-.84-.75-1.41-1.67-1.58-1.95-.16-.28-.02-.43.12-.57.12-.12.28-.32.42-.48.14-.16.18-.28.28-.46.1-.18.05-.34-.02-.48-.07-.14-.62-1.5-.85-2.06-.22-.53-.45-.46-.62-.46h-.53c-.18 0-.46.07-.7.34s-.92.9-.92 2.2.95 2.55 1.08 2.73c.14.18 1.87 2.86 4.54 4.02.64.28 1.14.45 1.53.58.64.2 1.22.17 1.68.1.51-.08 1.64-.67 1.87-1.31.23-.64.23-1.19.16-1.31-.06-.12-.25-.2-.53-.34z"/>
                    </svg>
                    {item.cta}
                  </a>
                )}
              </div>
            </details>
          ))}
        </div>

      </div>
    ))}
    </div>

    <div class="faq-dots" aria-hidden="true">
      {grupos.map((_, i) => <span class="dot" data-dot-idx={i} />)}
    </div>

  </div>
</section>

<script>
  const faqEl = document.getElementById("faq-groups");
  if (faqEl) {
    const dots = document.querySelectorAll<HTMLElement>(".faq-dots .dot");
    const isMobile = () => window.matchMedia("(max-width: 859px)").matches;

    const updateDots = () => {
      if (!isMobile()) return;
      const groups = faqEl.querySelectorAll<HTMLElement>(".faq-group");
      if (groups.length === 0) return;
      const groupWidth = (groups[0] as HTMLElement).offsetWidth + 14;
      const idx = Math.round(faqEl.scrollLeft / groupWidth);
      const clamped = Math.max(0, Math.min(dots.length - 1, idx));
      dots.forEach((d, i) => d.classList.toggle("active", i === clamped));
    };
    faqEl.addEventListener("scroll", updateDots, { passive: true });
    updateDots();

    // Preview-scroll inicial (mobile)
    let didPreview = false;
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting && !didPreview && isMobile()) {
          didPreview = true;
          setTimeout(() => {
            faqEl.scrollTo({ left: faqEl.clientWidth * 0.3, behavior: "smooth" });
            setTimeout(() => {
              faqEl.scrollTo({ left: 0, behavior: "smooth" });
            }, 900);
          }, 700);
        }
      });
    }, { threshold: 0.2 });
    io.observe(faqEl);
  }
</script>

<style>
  .faq {
    background: #fff;
    padding: 80px 24px;
    border-top: 1px solid #eee;
  }

  .inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* Swipe hint — solo mobile */
  .swipe-hint {
    display: none;
  }
  @media (max-width: 859px) {
    .swipe-hint {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      font-size: 12px;
      font-weight: 600;
      color: var(--brand);
      margin-bottom: 16px;
      animation: faq-swipe-pulse 2s ease-in-out infinite;
    }
  }
  @keyframes faq-swipe-pulse {
    0%, 100% { transform: translateX(0); opacity: 0.85; }
    50% { transform: translateX(6px); opacity: 1; }
  }

  /* Mobile: carrusel horizontal */
  .faq-groups {
    display: flex;
    flex-direction: row;
    gap: 14px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    margin: 0 -24px;
    padding: 4px 24px 8px;
  }
  .faq-groups::-webkit-scrollbar { display: none; }
  .faq-groups > .faq-group {
    flex: 0 0 auto;
    width: 90%;
    min-width: 0;
    scroll-snap-align: center;
  }

  /* Desktop: grid 2 cols */
  @media (min-width: 860px) {
    .faq-groups {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
      align-items: start;
      overflow: visible;
      margin: 0;
      padding: 0;
    }
    .faq-groups > .faq-group {
      width: auto;
    }
  }

  /* Dots indicators — solo mobile */
  .faq-dots {
    display: flex;
    gap: 7px;
    justify-content: center;
    margin-top: 18px;
  }
  .faq-dots .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #d1d5db;
    transition: background 0.25s, width 0.25s, border-radius 0.25s;
  }
  .faq-dots .dot.active {
    background: var(--brand);
    width: 22px;
    border-radius: 4px;
  }
  @media (min-width: 860px) {
    .faq-dots { display: none; }
  }

  /* Header */
  .header {
    text-align: center;
    margin-bottom: 56px;
  }
  .eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brand);
    margin-bottom: 12px;
  }
  h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 900;
    color: #111;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 10px;
  }
  .sec-sub {
    font-size: 15px;
    color: #6b7280;
  }

  /* Grupo */
  .faq-group {}

  .group-label {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }
  .group-icon {
    width: 32px;
    height: 32px;
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .group-icon.blue   { background: #EFF6FF; color: #3B82F6; }
  .group-icon.orange { background: var(--brand-lt); color: var(--brand); }

  .group-title {
    font-size: 13px;
    font-weight: 800;
    color: #111;
  }

  /* Acordeón */
  .faq-list {
    border: 1px solid #E5E7EB;
    border-radius: 18px;
    overflow: hidden;
  }

  .faq-item {
    border-bottom: 1px solid #E5E7EB;
  }
  .faq-item:last-child { border-bottom: none; }

  .faq-q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 22px;
    font-size: 14px;
    font-weight: 600;
    color: #111;
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: background 0.15s;
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-q:hover { background: #FAFAFA; }
  .faq-item[open] .faq-q { color: var(--brand); background: #FAFAFA; }

  .chevron {
    flex-shrink: 0;
    color: #9CA3AF;
    transition: transform 0.25s ease;
  }
  .faq-item[open] .chevron { transform: rotate(180deg); color: var(--brand); }

  .faq-body {
    padding: 0 22px 18px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    animation: fadeIn 0.2s ease;
  }
  .faq-body p {
    font-size: 13px;
    color: #6b7280;
    line-height: 1.75;
  }
  .faq-html {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .faq-html p {
    font-size: 13px;
    color: #6b7280;
    line-height: 1.75;
  }
  .faq-html strong {
    color: #374151;
  }

  .faq-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 16px;
    background: var(--brand);
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    border-radius: 9px;
    align-self: flex-start;
    transition: background 0.2s, transform 0.15s;
  }
  .faq-btn:hover {
    background: var(--brand-d);
    transform: translateY(-1px);
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
