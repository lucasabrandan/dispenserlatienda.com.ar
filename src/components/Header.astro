---
const NAV = [
  { label: "Servicios",     href: "#servicios"  },
  { label: "Casos reales",  href: "#trabajos"   },
  { label: "Nosotros",      href: "#nosotros"   },
  { label: "Reseñas",       href: "#resenas"    },
  { label: "FAQ",           href: "#faq"        },
  { label: "Contacto",      href: "#contacto"   },
];

const WA = "https://wa.me/5491166082608?text=" + encodeURIComponent("Hola, vengo de la web.");
---

<header class="site-header">
  <div class="header-inner">

    <!-- Logo + nombre -->
    <a href="/" class="brand" aria-label="Dispenser La Tienda — inicio">
      <img src="/logo.png" alt="Logo Dispenser La Tienda" width="34" height="34" />
      <span class="brand-name">Dispenser La Tienda</span>
    </a>

    <!-- Navegación — solo desktop -->
    <nav aria-label="Navegación principal">
      {NAV.map(({ label, href }) => (
        <a href={href}>{label}</a>
      ))}
    </nav>

    <!-- Botón WhatsApp — siempre visible -->
    <a href={WA} class="btn-wa" target="_blank" rel="noopener noreferrer">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
      </svg>
      <span class="wa-label">WhatsApp</span>
    </a>

  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(26, 26, 26, 0.97);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--dark-border);
  }

  .header-inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 12px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  /* Marca */
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  .brand img {
    height: 32px;
    width: auto;
  }
  .brand-name {
    font-weight: 800;
    font-size: 14px;
    color: #fff;
    white-space: nowrap;
  }

  /* Nav — solo desktop */
  nav {
    display: none;
    gap: 22px;
  }
  @media (min-width: 900px) {
    nav { display: flex; }
  }
  nav a {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.55);
    font-weight: 500;
    transition: color 0.2s;
  }
  nav a:hover { color: var(--brand); }

  /* Botón WhatsApp — siempre visible */
  .btn-wa {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 16px;
    background: var(--brand);
    color: #fff;
    font-weight: 700;
    font-size: 14px;
    border-radius: 12px;
    box-shadow: 0 6px 20px rgba(255, 123, 3, 0.3);
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .btn-wa:hover {
    background: var(--brand-d);
    transform: translateY(-1px);
  }

  /* El texto siempre visible */
  .wa-label { display: inline; }
</style>
