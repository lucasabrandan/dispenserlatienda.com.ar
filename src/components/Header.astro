---
const NAV = [
  { label: "Servicios",  href: "#servicios"  },
  { label: "Equipos",    href: "#equipos"    },
  { label: "Nosotros",   href: "#nosotros"   },
  { label: "Reseñas",    href: "#resenas"    },
  { label: "FAQ",        href: "#faq"        },
  { label: "Contacto",   href: "#contacto"   },
];

const WA = "https://wa.me/5491166082608?text=" + encodeURIComponent("Hola, vengo de la web.");
---

<header class="site-header">
  <div class="header-inner">

    <!-- Logo + nombre -->
    <a href="/" class="brand" aria-label="Dispenser La Tienda — inicio">
      <img src="/logo.png" alt="Logo Dispenser La Tienda" width="34" height="34" />
      <span class="brand-name">Dispenser La Tienda</span>
    </a>

    <!-- Navegación — solo desktop -->
    <nav aria-label="Navegación principal">
      {NAV.map(({ label, href }) => (
        <a href={href}>{label}</a>
      ))}
    </nav>

    <!-- Botón WhatsApp — siempre visible -->
    <a href={WA} class="btn-wa" target="_blank" rel="noopener noreferrer">
      <svg width="16" height="16" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
        <path d="M19.11 17.25c-.28-.14-1.64-.81-1.89-.9s-.44-.14-.62.14c-.18.28-.71.9-.87 1.08-.16.18-.32.2-.6.07-.28-.14-1.2-.44-2.28-1.4-.84-.75-1.41-1.67-1.58-1.95-.16-.28-.02-.43.12-.57.12-.12.28-.32.42-.48.14-.16.18-.28.28-.46.1-.18.05-.34-.02-.48-.07-.14-.62-1.5-.85-2.06-.22-.53-.45-.46-.62-.46h-.53c-.18 0-.46.07-.7.34s-.92.9-.92 2.2.95 2.55 1.08 2.73c.14.18 1.87 2.86 4.54 4.02.64.28 1.14.45 1.53.58.64.2 1.22.17 1.68.1.51-.08 1.64-.67 1.87-1.31.23-.64.23-1.19.16-1.31-.06-.12-.25-.2-.53-.34z"/>
      </svg>
      <span class="wa-label">WhatsApp</span>
    </a>

  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(26, 26, 26, 0.97);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--dark-border);
  }

  .header-inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 12px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  /* Marca */
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  .brand img {
    height: 32px;
    width: auto;
  }
  .brand-name {
    font-weight: 800;
    font-size: 14px;
    color: #fff;
    white-space: nowrap;
  }

  /* Nav — solo desktop */
  nav {
    display: none;
    gap: 22px;
  }
  @media (min-width: 900px) {
    nav { display: flex; }
  }
  nav a {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.55);
    font-weight: 500;
    transition: color 0.2s;
  }
  nav a:hover { color: var(--brand); }

  /* Botón WhatsApp — siempre visible */
  .btn-wa {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 16px;
    background: var(--brand);
    color: #fff;
    font-weight: 700;
    font-size: 14px;
    border-radius: 12px;
    box-shadow: 0 6px 20px rgba(255, 123, 3, 0.3);
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .btn-wa:hover {
    background: var(--brand-d);
    transform: translateY(-1px);
  }

  /* En mobile ocultamos el texto y dejamos solo el ícono */
  .wa-label { display: none; }
  @media (min-width: 480px) {
    .wa-label { display: inline; }
  }
</style>
