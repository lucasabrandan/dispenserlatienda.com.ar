---
type Spec = { k: string; v: string };

type Producto = {
  id: string;
  nombre: string;
  subtitulo: string;
  descripcion: string;
  imagenes: string[];
  imagenesRed?: string[];
  imagenAlt: string;
  bullets: string[];
  specs: Spec[];
  hasToggle: boolean;
  badge?: string;
  infoFijo?: boolean;
  origen: "nacional" | "premium";
  linea?: "classic" | "pro";
  waBotellon?: string;
  waRed?: string;
  waUnico?: string;
};

interface Props {
  producto: Producto;
}

const { producto: p } = Astro.props;

import { PHONE, COBERTURA } from "../config/site";
const WA = (text: string) => `https://wa.me/${PHONE.raw}?text=${encodeURIComponent(text + " 🛒")}`;
---

<article class="card-equipo reveal" data-product-id={p.id}>
  {p.badge && <span class="badge">{p.badge}</span>}

  <div
    class="card-imagen galeria"
    data-imagenes-botellon={JSON.stringify(p.imagenes)}
    data-imagenes-red={JSON.stringify(p.imagenesRed ?? p.imagenes)}
  >
    <div class="galeria-main">
      <img
        src={p.imagenes[0]}
        alt={p.imagenAlt}
        loading="lazy"
        width="400"
        height="500"
        draggable="false"
        class="galeria-img"
        data-galeria-main
      />
      <div class="galeria-overlay" aria-hidden="true"></div>
    </div>
    {p.imagenes.length > 1 && (
      <div class="galeria-thumbs" role="tablist" aria-label="Otras vistas del producto">
        {p.imagenes.map((img, idx) => (
          <button
            type="button"
            class:list={["galeria-thumb", { active: idx === 0 }]}
            data-image={img}
            data-image-idx={idx}
            aria-label={`Ver imagen ${idx + 1}`}
            role="tab"
            aria-selected={idx === 0 ? "true" : "false"}
          >
            <img src={img} alt="" loading="lazy" draggable="false" />
          </button>
        ))}
      </div>
    )}
  </div>

  <div class="card-body">
    <h3 class="card-title">{p.nombre}</h3>
    <p class="card-subtitle">{p.subtitulo}</p>

    <a
      href={p.hasToggle ? WA(p.waBotellon!) : WA(p.waUnico!)}
      class="btn-cotizar"
      target="_blank"
      rel="noopener noreferrer"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
      </svg>
      <span class="btn-text">{p.badge ? "Consultar disponibilidad" : "Cotizar por WhatsApp"}</span>
    </a>

    <button type="button" class="ver-mas-btn" aria-expanded="false">
      <span class="ver-mas-text">Ver detalles</span>
      <svg class="ver-mas-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </button>

    <div class="card-detalles">
      {p.hasToggle && (
        <div class="toggle-wrap" role="tablist" aria-label="Tipo de instalación">
          <button
            type="button"
            class="toggle-variant active"
            data-variant="botellon"
            data-wa-msg={p.waBotellon}
            role="tab"
            aria-selected="true"
          >
            Botellón
          </button>
          <button
            type="button"
            class="toggle-variant"
            data-variant="red"
            data-wa-msg={p.waRed}
            role="tab"
            aria-selected="false"
          >
            Red de agua
          </button>
        </div>
      )}

      {(p.hasToggle || p.infoFijo) && (
        <div class:list={["info-red", { "is-hidden": p.hasToggle && !p.infoFijo }]}>
          <div class="info-red-title">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 2.69 5.66 9.03a8 8 0 1 0 12.68 0z"/>
            </svg>
            Conexión directa a la red
          </div>
          <p class="info-red-text">Esta versión requiere:</p>
          <ul class="info-red-list">
            <li>Filtro previo (cotiza aparte)</li>
            <li>Kit de conexión a cañería</li>
          </ul>
          <p class="info-red-zone">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            Instalación a domicilio disponible en <strong>{COBERTURA.despacho}</strong>
          </p>
        </div>
      )}

      <p class="card-desc">{p.descripcion}</p>

      <ul class="bullets" role="list">
        {p.bullets.map((b) => (
          <li>{b}</li>
        ))}
      </ul>

      <details class="specs">
        <summary>Especificaciones técnicas</summary>
        <table>
          <tbody>
            {p.specs.map((s) => (
              <tr>
                <th>{s.k}</th>
                <td>{s.v}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </details>
    </div>
  </div>
</article>
