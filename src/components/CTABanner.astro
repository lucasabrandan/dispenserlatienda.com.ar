---
import { EMAIL, SITE } from "../config/site";

const subject = encodeURIComponent(`Solicitud de cotización – ${SITE.name}`);
const body = encodeURIComponent(
  "Hola, me comunico desde la web para solicitar una cotización.\n\n" +
  "Nombre o empresa: \n" +
  "Dirección / Ubicación de los equipos: \n" +
  "Cantidad de equipos: \n" +
  "Marca y modelo: \n" +
  "Diagnóstico / problema: \n\n" +
  "Quedo a la espera, gracias."
);
const MAIL = `mailto:${EMAIL}?subject=${subject}&body=${body}`;
---

<section class="cta-banner">
  <div class="inner">
    <div class="text">
      <p class="cta-eyebrow">Para empresas</p>
      <h2>¿Tenés más de un equipo?</h2>
      <p class="cta-sub">Consultá por nuestro plan de mantenimiento para empresas y el descuento para 5 equipos o más.</p>
    </div>
    <a href={MAIL} class="btn-cta">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
      </svg>
      Solicitar cotización por email
    </a>
  </div>
</section>

<style>
  .cta-banner {
    background: var(--brand);
    padding: 56px 24px;
  }

  .inner {
    max-width: 980px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
    text-align: center;
  }
  @media (min-width: 720px) {
    .inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .text {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cta-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.4);
  }

  h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .cta-sub {
    font-size: 15px;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
    max-width: 52ch;
  }

  .btn-cta {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 14px 28px;
    background: #fff;
    color: var(--brand);
    font-size: 15px;
    font-weight: 800;
    border-radius: 13px;
    white-space: nowrap;
    flex-shrink: 0;
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .btn-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.2);
  }
</style>
