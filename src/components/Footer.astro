---
const SERVICIOS = [
  "Mantenimiento",
  "Reparación",
  "Limpieza y desinfección",
  "Conversión a red",
];

const PRODUCTOS = [
  "Dispensers nuevos",
  "Filtros de mesada",
  "Catálogo de repuestos",
];

const REDES = [
  { label: "TikTok",    href: "https://www.tiktok.com/@dispenserlatienda",         icon: "🎵" },
  { label: "Instagram", href: "https://www.instagram.com/dispenserlatienda/",      icon: "📸" },
  { label: "Google",    href: "https://share.google/DoOJd5YC6DhjIgZ2D",            icon: "⭐" },
  { label: "WhatsApp",  href: "https://wa.me/5491166082608",                        icon: "💬" },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-top">

    <!-- Columna marca -->
    <div class="footer-brand">
      <a href="/" aria-label="Inicio">
        <img src="/logo.png" alt="Logo Dispenser La Tienda" width="36" height="36" />
      </a>
      <p>Servicio técnico y venta de dispensers a domicilio en CABA y GBA. Desde 2018.</p>
      <div class="footer-contact">
        <span>📞 +54 9 11 6608-2608</span>
        <span>✉️ dispenserlatienda@gmail.com</span>
      </div>
    </div>

    <!-- Servicios -->
    <div class="footer-col">
      <h4>Servicios</h4>
      {SERVICIOS.map(s => <a href="#servicios">{s}</a>)}
    </div>

    <!-- Productos -->
    <div class="footer-col">
      <h4>Productos</h4>
      {PRODUCTOS.map(p => <a href="#equipos">{p}</a>)}
    </div>

    <!-- Contacto -->
    <div class="footer-col">
      <h4>Encontranos en</h4>
      {REDES.map(({ label, href, icon }) => (
        <a href={href} target="_blank" rel="noopener noreferrer">
          {icon} {label}
        </a>
      ))}
    </div>

  </div>

  <div class="footer-bottom">
    <span class="footer-copy">© {year} Dispenser La Tienda · CABA y Gran Buenos Aires</span>
    <div class="footer-social">
      {REDES.map(({ label, href, icon }) => (
        <a href={href} class="social-btn" target="_blank" rel="noopener noreferrer" aria-label={label}>
          {icon}
        </a>
      ))}
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #111;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: 56px 24px 32px;
  }

  .footer-top {
    max-width: 1180px;
    margin: 0 auto 40px;
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 40px;
  }
  @media (max-width: 900px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 540px) {
    .footer-top {
      grid-template-columns: 1fr;
    }
  }

  /* Columna marca */
  .footer-brand img {
    height: 36px;
    width: auto;
    margin-bottom: 12px;
  }
  .footer-brand p {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.4);
    line-height: 1.65;
    max-width: 26ch;
    margin-bottom: 14px;
  }
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.35);
  }

  /* Columnas nav */
  .footer-col h4 {
    font-size: 11px;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.45);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 14px;
  }
  .footer-col a {
    display: block;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 9px;
    transition: color 0.2s;
  }
  .footer-col a:hover { color: var(--brand); }

  /* Footer bottom */
  .footer-bottom {
    max-width: 1180px;
    margin: 0 auto;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
  }
  .footer-copy {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.28);
  }
  .footer-social {
    display: flex;
    gap: 8px;
  }
  .social-btn {
    width: 34px;
    height: 34px;
    border-radius: 9px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    display: grid;
    place-items: center;
    font-size: 15px;
    transition: background 0.2s, border-color 0.2s;
  }
  .social-btn:hover {
    background: rgba(255, 123, 3, 0.15);
    border-color: var(--brand);
  }
</style>
