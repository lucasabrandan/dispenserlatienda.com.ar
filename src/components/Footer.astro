        WhatsApp
      </a>
    </div>

  </div>

  <div class="footer-bottom">
    <span class="footer-copy">© {year} {SITE.name} · {COBERTURA.short}</span>
    <div class="footer-social">
      <a href={SOCIAL.tiktok} class="social-btn" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
      </a>
      <a href={SOCIAL.instagram} class="social-btn" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
      </a>
      <a href={SOCIAL.google} class="social-btn" target="_blank" rel="noopener noreferrer" aria-label="Google Business">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 11h8.533c.044.385.067.78.067 1.184 0 2.734-.98 5.036-2.678 6.6C16.42 20.272 14.36 21 12 21c-4.97 0-9-4.03-9-9s4.03-9 9-9c2.395 0 4.404.868 5.96 2.288l-2.36 2.36C14.688 6.765 13.415 6.3 12 6.3 9.134 6.3 6.8 8.634 6.8 11.5S9.134 16.7 12 16.7c2.442 0 4.188-1.318 4.76-3.2H12v-2.5z"/></svg>
      </a>
      <a href={WA.plain} class="social-btn" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" data-wa-event="footer-social">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.117.549 4.107 1.51 5.837L.057 23.704a.75.75 0 0 0 .92.92l5.867-1.453A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.696 9.696 0 0 1-4.944-1.353l-.355-.21-3.668.909.924-3.58-.23-.368A9.698 9.698 0 0 1 2.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/></svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #111;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: 56px 24px 32px;
  }

  .footer-top {
    max-width: 1180px;
    margin: 0 auto 40px;
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 40px;
  }
  @media (max-width: 900px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 540px) {
    .footer-top {
      grid-template-columns: 1fr;
    }
  }

  /* Columna marca */
  .footer-brand img {
    height: 36px;
    width: auto;
    margin-bottom: 12px;
  }
  .footer-brand p {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.4);
    line-height: 1.65;
    max-width: 26ch;
    margin-bottom: 14px;
  }
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.35);
  }

  /* Columnas nav */
  .footer-col h4 {
    font-size: 11px;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.45);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 14px;
  }
  .footer-col a {
    display: block;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 9px;
    transition: color 0.2s;
  }
  .footer-col a:hover { color: var(--brand); }
  .red-link {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* Footer bottom */
  .footer-bottom {
    max-width: 1180px;
    margin: 0 auto;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
  }
  .footer-copy {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.28);
  }
  .footer-social {
    display: flex;
    gap: 8px;
  }
  .social-btn {
    width: 34px;
    height: 34px;
    border-radius: 9px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    display: grid;
    place-items: center;
    font-size: 15px;
    transition: background 0.2s, border-color 0.2s;
  }
  .social-btn:hover {
    background: rgba(255, 123, 3, 0.15);
    border-color: var(--brand);
  }
</style>
