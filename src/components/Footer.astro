---
import { SITE, PHONE, EMAIL, WA, SOCIAL, COBERTURA } from "../config/site";

const SERVICIOS = [
  "Mantenimiento",
  "Reparación",
  "Limpieza y desinfección",
  "Conversión a red",
];

const REDES = [
  { label: "TikTok",    href: SOCIAL.tiktok },
  { label: "Instagram", href: SOCIAL.instagram },
  { label: "Google",    href: SOCIAL.google },
  { label: "WhatsApp",  href: WA.plain },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-top">

    <!-- Columna marca -->
    <div class="footer-brand">
      <a href="/" aria-label="Inicio">
        <img src="/logo.png" alt="Logo Dispenser La Tienda" width="36" height="36" />
      </a>
      <p>Servicio técnico de dispensers a domicilio en {COBERTURA.short}. Desde {SITE.since}.</p>
      <div class="footer-contact">
        <span>{PHONE.display}</span>
        <span>{EMAIL}</span>
      </div>
    </div>

    <!-- Servicios -->
    <div class="footer-col">
      <h4>Servicios</h4>
      {SERVICIOS.map(s => <a href="#servicios">{s}</a>)}
    </div>

    <!-- Redes -->
    <div class="footer-col">
      <h4>Encontranos en</h4>
      <a href={SOCIAL.tiktok} target="_blank" rel="noopener noreferrer" class="red-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
        TikTok
