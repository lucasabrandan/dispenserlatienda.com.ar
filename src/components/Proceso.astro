---
const pasos = [
  {
    n: 1,
    title: "Escribinos por WhatsApp",
    desc: "Contanos qué necesitás. Si es reparación, mandanos fotos y el modelo del equipo.",
  },
  {
    n: 2,
    title: "Te pasamos un estimativo",
    desc: "Antes de confirmar nada, te decimos el costo aproximado del trabajo.",
  },
  {
    n: 3,
    title: "Coordinamos la visita",
    desc: "Acordamos el día y horario que mejor te quede. Visita en 24 a 48 horas.",
  },
  {
    n: 4,
    title: "El trabajo y la garantía",
    desc: "Resolvemos en esa misma visita y te entregamos factura con garantía incluida.",
  },
];
---

<section class="proceso" id="proceso">
  <div class="inner">

    <div class="header">
      <span class="eyebrow">¿Cómo funciona?</span>
      <h2>Simple y sin vueltas</h2>
      <p class="sec-sub">Coordinamos todo por WhatsApp para que no tengas que moverte.</p>
    </div>

    <p class="swipe-hint" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
      Deslizá para ver los pasos
    </p>

    <ol class="steps" id="proceso-steps" role="list">
      {pasos.map((paso) => (
        <li class={`step ${paso.n === 1 ? "step--first" : ""}`}>
          <div class="step-num" aria-hidden="true">{paso.n}</div>
          <div class="step-body">
            <strong class="step-title">{paso.title}</strong>
            <p class="step-desc">{paso.desc}</p>
          </div>
        </li>
      ))}
    </ol>

    <div class="steps-dots" aria-hidden="true">
      {pasos.map((_, i) => <span class="dot" data-dot-idx={i} />)}
    </div>

  </div>
</section>

<script>
  const stepsEl = document.getElementById("proceso-steps");
  if (stepsEl) {
    const dots = document.querySelectorAll<HTMLElement>(".steps-dots .dot");
    const isMobile = () => window.matchMedia("(max-width: 719px)").matches;

    const updateDots = () => {
      if (!isMobile()) return;
      const steps = stepsEl.querySelectorAll<HTMLElement>(".step");
      if (steps.length === 0) return;
      const stepWidth = (steps[0] as HTMLElement).offsetWidth + 12;
      const idx = Math.round(stepsEl.scrollLeft / stepWidth);
      const clamped = Math.max(0, Math.min(dots.length - 1, idx));
      dots.forEach((d, i) => d.classList.toggle("active", i === clamped));
    };
    stepsEl.addEventListener("scroll", updateDots, { passive: true });
    updateDots();

    // Preview-scroll inicial (mobile)
    let didPreview = false;
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting && !didPreview && isMobile()) {
          didPreview = true;
          setTimeout(() => {
            stepsEl.scrollTo({ left: stepsEl.clientWidth * 0.35, behavior: "smooth" });
            setTimeout(() => {
              stepsEl.scrollTo({ left: 0, behavior: "smooth" });
            }, 900);
          }, 700);
        }
      });
    }, { threshold: 0.3 });
    io.observe(stepsEl);
  }
</script>

<style>
  .proceso {
    background: #F8F8F8;
    padding: 72px 24px 80px;
    border-top: 1px solid #eee;
  }

  .inner {
    max-width: 980px;
    margin: 0 auto;
  }

  /* Header */
  .header {
    text-align: center;
    margin-bottom: 56px;
  }
  .eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brand);
    margin-bottom: 12px;
  }
  h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 900;
    color: #111;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 10px;
  }
  .sec-sub {
    font-size: 15px;
    color: #6b7280;
    line-height: 1.6;
  }

  /* Swipe hint — solo mobile */
  .swipe-hint {
    display: none;
  }
  @media (max-width: 719px) {
    .swipe-hint {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      font-size: 12px;
      font-weight: 600;
      color: var(--brand);
      margin-bottom: 16px;
      animation: proceso-swipe-pulse 2s ease-in-out infinite;
    }
  }
  @keyframes proceso-swipe-pulse {
    0%, 100% { transform: translateX(0); opacity: 0.85; }
    50% { transform: translateX(6px); opacity: 1; }
  }

  /* Steps — mobile: carrusel horizontal */
  .steps {
    list-style: none;
    display: flex;
    flex-direction: row;
    gap: 12px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    margin: 0 -24px;
    padding: 0 24px 4px;
    position: relative;
  }
  .steps::-webkit-scrollbar { display: none; }

  /* Steps — desktop: grid 4 cols con línea conectora */
  @media (min-width: 720px) {
    .steps {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      overflow: visible;
      margin: 0;
      padding: 0;
    }
    .steps::before {
      content: '';
      position: absolute;
      top: 27px;
      left: calc(12.5% + 16px);
      right: calc(12.5% + 16px);
      height: 1px;
      background: linear-gradient(90deg, var(--brand), rgba(255,123,3,0.2));
    }
  }

  /* Step individual */
  .step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 16px;
    position: relative;
  }

  /* Mobile: cada step ocupa ~75% del ancho, con scroll-snap */
  @media (max-width: 719px) {
    .step {
      flex: 0 0 auto;
      width: 75%;
      min-width: 0;
      scroll-snap-align: center;
      padding: 8px 16px;
    }
  }

  /* Dots indicators — solo mobile */
  .steps-dots {
    display: flex;
    gap: 7px;
    justify-content: center;
    margin-top: 18px;
  }
  .steps-dots .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #d1d5db;
    transition: background 0.25s, width 0.25s, border-radius 0.25s;
  }
  .steps-dots .dot.active {
    background: var(--brand);
    width: 22px;
    border-radius: 4px;
  }
  @media (min-width: 720px) {
    .steps-dots { display: none; }
  }

  /* Número */
  .step-num {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 900;
    position: relative;
    z-index: 1;
    margin-bottom: 20px;
    flex-shrink: 0;
    background: #fff;
    border: 2px solid var(--brand);
    color: var(--brand);
  }
  .step--first .step-num {
    background: var(--brand);
    color: #fff;
  }

  .step-body { max-width: 200px; }

  .step-title {
    display: block;
    font-size: 15px;
    font-weight: 800;
    color: #111;
    margin-bottom: 8px;
  }
  .step-desc {
    font-size: 13px;
    color: #6b7280;
    line-height: 1.6;
  }
</style>
