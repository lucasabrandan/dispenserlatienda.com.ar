---
import { WA, COBERTURA } from "../config/site";
---

<section class="servicios" id="servicios">

  <div class="sec-header">
    <span class="eyebrow">Lo que hacemos</span>
    <h2>Servicio técnico<br>a domicilio</h2>
    <p class="sec-sub">Vamos a tu empresa u oficina. Sin turnos, sin traslados.</p>
  </div>

  <div class="split-wrap">
    <p class="swipe-hint" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
      Deslizá para ver más
    </p>
    <div class="split" id="servicios-split">

      <!-- Panel izquierdo — Limpieza (destacado) -->
      <div class="panel-dark">
        <div class="panel-tag" aria-label="Servicio más solicitado">
          <span class="tag-dot" aria-hidden="true"></span>
          Más solicitado
        </div>

        <div class="panel-icon dark-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </div>

        <h3 class="panel-title dark-title">Limpieza y<br>cambio de filtro</h3>

        <p class="panel-desc dark-desc">
          Una vez al año es todo lo que necesita tu equipo. Cambiamos el filtro y hacemos la limpieza completa del circuito en una sola visita.
        </p>

        <ul class="panel-list dark-list" role="list">
          <li>Recomendado cada 12 meses</li>
          <li>Limpieza profunda del circuito interno</li>
          <li>Descuento para 5 equipos o más</li>
          <li>Garantía de 90 días incluida</li>
        </ul>

        <a href={WA.limpieza} class="btn-primary" target="_blank" rel="noopener noreferrer" data-wa-event="limpieza">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          Consultar precio
        </a>
        <a href="/limpieza-y-cambio-de-filtro" class="link-more dark-link-more">Conocé el servicio →</a>
      </div>

      <!-- Panel derecho — Reparación -->
      <div class="panel-light">

        <div class="panel-icon light-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
          </svg>
        </div>

        <h3 class="panel-title light-title">Reparación<br>de dispensers</h3>

        <p class="panel-desc light-desc">
          Antes de ir, coordinamos por WhatsApp. Mandanos fotos y el modelo del equipo, te pasamos un estimativo y si lo confirmás, acordamos el día y horario de la visita.
        </p>

        <ul class="panel-list light-list" role="list">
          <li>Diagnóstico previo por WhatsApp</li>
          <li>Estimativo de costo sin compromiso</li>
          <li>Coordinamos día y horario a tu medida</li>
          <li>Garantía de 3 meses sobre el trabajo</li>
        </ul>

        <a href={WA.reparacion} class="btn-outline" target="_blank" rel="noopener noreferrer" data-wa-event="reparacion">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          Consultar
        </a>

        <a href="/reparacion-dispenser" class="link-more">Conocé el servicio →</a>

        <div class="factura-note" aria-label="Emitimos factura por todos los trabajos">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
          </svg>
          Emitimos factura por todos los trabajos
        </div>

      </div>

      <!-- Panel — Conversión bidón a red de agua -->
      <div class="panel-light">

        <div class="panel-icon light-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="17 1 21 5 17 9"/>
            <path d="M3 11V9a4 4 0 0 1 4-4h14"/>
            <polyline points="7 23 3 19 7 15"/>
            <path d="M21 13v2a4 4 0 0 1-4 4H3"/>
          </svg>
        </div>

        <h3 class="panel-title light-title">Conversión<br>de bidón a red</h3>

        <p class="panel-desc light-desc">
          ¿Tu equipo es de bidón pero no conseguís repuestos? Lo adaptamos para que se conecte directo a la red de agua. Incluye kit con filtro flotante y tapa ciega más la instalación a domicilio.
        </p>

        <ul class="panel-list light-list" role="list">
          <li>Adaptación de equipos sin repuestos disponibles</li>
          <li>Kit incluido: filtro flotante + tapa ciega</li>
          <li>Instalación a domicilio incluida</li>
          <li>Solo en {COBERTURA.despacho}</li>
        </ul>

        <a href={WA.conversion} class="btn-outline" target="_blank" rel="noopener noreferrer" data-wa-event="conversion">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          Consultar
        </a>
        <a href="/conversion-bidon-a-red" class="link-more">Conocé el servicio →</a>

      </div>

    </div>

    <div class="split-dots" aria-hidden="true">
      <span class="dot" data-dot-idx="0"></span>
      <span class="dot" data-dot-idx="1"></span>
      <span class="dot" data-dot-idx="2"></span>
    </div>
  </div>

</section>

<script>
  const split = document.getElementById("servicios-split");
  if (split) {
    const dots = document.querySelectorAll<HTMLElement>(".split-dots .dot");
    const isMobile = () => window.matchMedia("(max-width: 719px)").matches;

    // Update dot indicator based on scroll position
    const updateDots = () => {
      if (!isMobile()) return;
      const idx = Math.round(split.scrollLeft / (split.clientWidth * 0.92));
      dots.forEach((d, i) => d.classList.toggle("active", i === idx));
    };
    split.addEventListener("scroll", updateDots, { passive: true });
    updateDots();

    // Preview-scroll inicial: al entrar en viewport por primera vez (solo mobile)
    let didPreview = false;
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting && !didPreview && isMobile()) {
          didPreview = true;
          setTimeout(() => {
            split.scrollTo({ left: split.clientWidth * 0.4, behavior: "smooth" });
            setTimeout(() => {
              split.scrollTo({ left: 0, behavior: "smooth" });
            }, 900);
          }, 600);
        }
      });
    }, { threshold: 0.4 });
    io.observe(split);
  }
</script>

<style>
  /* ===== Sección ===== */
  .servicios {
    background: #F8F8F8;
    padding: 72px 24px 80px;
  }

  /* Header */
  .sec-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brand);
    margin-bottom: 12px;
  }
  h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 900;
    color: #111;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 10px;
  }
  .sec-sub {
    font-size: 15px;
    color: #6b7280;
    line-height: 1.6;
  }

  /* ===== Split ===== */
  .split-wrap {
    max-width: 980px;
    margin: 0 auto;
  }

  /* Hint "Deslizá para ver más" — solo mobile */
  .swipe-hint {
    display: none;
  }
  @media (max-width: 719px) {
    .swipe-hint {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      font-size: 12px;
      font-weight: 600;
      color: var(--brand);
      margin-bottom: 14px;
      animation: swipe-hint-pulse 2s ease-in-out infinite;
    }
  }
  @keyframes swipe-hint-pulse {
    0%, 100% { transform: translateX(0); opacity: 0.85; }
    50% { transform: translateX(6px); opacity: 1; }
  }

  /* Mobile: carrusel horizontal */
  .split {
    display: flex;
    flex-direction: row;
    gap: 12px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    margin: 0 -24px;
    padding: 0 24px 4px;
  }
  .split::-webkit-scrollbar { display: none; }
  .split > * {
    flex: 0 0 88%;
    scroll-snap-align: center;
    border-radius: 22px;
    border: 1px solid #E5E7EB;
  }

  /* Desktop: vuelve al grid (3 columnas) */
  @media (min-width: 720px) {
    .split {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 0;
      margin: 0;
      padding: 0;
      overflow: hidden;
      border-radius: 22px;
      border: 1px solid #E5E7EB;
    }
    .split > * {
      flex: none;
      border-radius: 0;
      border: 0;
    }
    /* Línea separadora vertical entre paneles claros */
    .split > .panel-light + .panel-light {
      border-left: 1px solid #E5E7EB;
    }
  }

  /* Dots indicators — solo mobile */
  .split-dots {
    display: flex;
    gap: 8px;
    justify-content: center;
    margin-top: 18px;
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #d1d5db;
    transition: background 0.25s, width 0.25s, border-radius 0.25s;
  }
  .dot.active {
    background: var(--brand);
    width: 24px;
    border-radius: 4px;
  }
  @media (min-width: 720px) {
    .split-dots { display: none; }
  }

  /* ===== Panel compartido ===== */
  .panel-dark,
  .panel-light {
    padding: 44px 36px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  @media (max-width: 480px) {
    .panel-dark, .panel-light { padding: 32px 24px; }
  }

  .panel-icon {
    width: 52px;
    height: 52px;
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .panel-title {
    font-size: clamp(1.3rem, 2.5vw, 1.7rem);
    font-weight: 900;
    line-height: 1.2;
  }
  .panel-desc {
    font-size: 14px;
    line-height: 1.7;
  }
  .panel-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 9px;
    margin-top: 4px;
  }
  .panel-list li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
  }
  .panel-list li::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--brand);
    flex-shrink: 0;
  }

  /* ===== Panel oscuro ===== */
  .panel-dark {
    background: #111;
    position: relative;
    overflow: hidden;
  }
  .panel-dark::before {
    content: '';
    position: absolute;
    top: -60px; left: -60px;
    width: 280px; height: 280px;
    background: radial-gradient(ellipse, rgba(255,123,3,0.12) 0%, transparent 70%);
    pointer-events: none;
  }
  @media (min-width: 720px) {
    .panel-dark { border-right: 1px solid rgba(255,255,255,0.06); }
  }

  .panel-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand);
    background: rgba(255,123,3,0.12);
    border: 1px solid rgba(255,123,3,0.2);
    padding: 4px 12px;
    border-radius: 999px;
    align-self: flex-start;
  }
  .tag-dot {
    width: 6px; height: 6px;
    background: var(--brand);
    border-radius: 50%;
  }

  .dark-icon {
    background: rgba(255,123,3,0.12);
    color: var(--brand);
  }
  .dark-title { color: #fff; }
  .dark-desc  { color: rgba(255,255,255,0.5); }
  .dark-list li { color: rgba(255,255,255,0.7); }

  /* ===== Panel claro ===== */
  .panel-light { background: #fff; }

  .light-icon {
    background: var(--brand-lt);
    color: var(--brand);
  }
  .light-title { color: #111; }
  .light-desc  { color: #6b7280; }
  .light-list li { color: #374151; }

  /* ===== Botones ===== */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: var(--brand);
    color: #fff;
    font-weight: 700;
    font-size: 14px;
    border-radius: 12px;
    align-self: flex-start;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-primary:hover {
    background: var(--brand-d);
    transform: translateY(-1px);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: transparent;
    border: 1.5px solid rgba(255,123,3,0.4);
    color: var(--brand);
    font-weight: 700;
    font-size: 14px;
    border-radius: 12px;
    align-self: flex-start;
    transition: background 0.2s, border-color 0.2s;
  }
  .btn-outline:hover {
    background: var(--brand-lt);
    border-color: var(--brand);
  }

  /* ===== Nota factura ===== */
  .factura-note {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: #9CA3AF;
    padding-top: 16px;
    margin-top: auto;
    border-top: 1px solid #F3F4F6;
  }
  .factura-note svg { color: #9CA3AF; flex-shrink: 0; }

  /* Link "Conocé el servicio" */
  .link-more {
    font-size: 13px;
    font-weight: 600;
    color: var(--brand);
    align-self: flex-start;
    transition: opacity 0.2s;
  }
  .link-more:hover { opacity: 0.75; }
  .dark-link-more { color: rgba(255,255,255,0.5); }
  .dark-link-more:hover { color: var(--brand); opacity: 1; }
</style>
