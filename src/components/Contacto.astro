---
import { WA, PHONE, EMAIL, COBERTURA, HORARIO, ZONAS } from "../config/site";
---

<section class="contacto" id="contacto">
  <div class="inner">
    <div class="layout">

      <!-- Info -->
      <div class="info">
        <span class="eyebrow">Contacto</span>
        <h2>¿Tenés un dispenser<br>con <em>problemas</em>?</h2>
        <p class="lead">Completá el formulario y te abrimos WhatsApp con el mensaje ya armado. Sin esperas, sin llamadas.</p>

        <ul class="contact-list" role="list">
          <li class="contact-item">
            <div class="contact-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div class="contact-text">
              <strong>Cobertura</strong>
              <span>{COBERTURA.short}</span>
            </div>
          </li>
          <li class="contact-item">
            <div class="contact-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
              </svg>
            </div>
            <div class="contact-text">
              <strong>Horario</strong>
              <span>{HORARIO.display} · Respuesta inmediata</span>
            </div>
          </li>
          <li class="contact-item">
            <div class="contact-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div class="contact-text">
              <strong>Email</strong>
              <span>{EMAIL}</span>
            </div>
          </li>
        </ul>
      </div>

      <!-- Formulario -->
      <form class="form-card" id="contact-form" novalidate>
        <div class="form-row">
          <label for="nombre">Tu nombre o empresa</label>
          <input type="text" id="nombre" name="nombre" placeholder="Ej: Consultorio López" autocomplete="name" />
        </div>
        <div class="form-row">
          <label for="servicio">¿Qué necesitás?</label>
          <select id="servicio" name="servicio">
            <option value="" disabled selected>Seleccioná un servicio</option>
            <option value="Limpieza y cambio de filtro">Limpieza y cambio de filtro</option>
            <option value="Reparación de dispenser">Reparación de dispenser</option>
            <option value="Conversión bidón a red">Conversión bidón a red</option>
            <option value="Alquiler corporativo">Alquiler corporativo</option>
            <option value="Consulta general">Consulta general</option>
          </select>
        </div>
        <div class="form-row zona-row">
          <label for="zona">¿En qué zona estás?</label>
          <div class="zona-wrap">
            <input type="text" id="zona" name="zona" placeholder="Escribí tu localidad..." autocomplete="off" />
            <ul id="zona-suggestions" class="zona-suggestions" role="listbox" style="display:none;"></ul>
          </div>
          <p id="zona-hint" class="zona-hint" style="display:none;"></p>
        </div>
        <div class="form-row">
          <label for="telefono">Tu teléfono (opcional)</label>
          <input type="tel" id="telefono" name="telefono" placeholder="Ej: 11 2345-6789" autocomplete="tel" />
        </div>
        <div class="form-row">
          <label for="mensaje">Contanos más (opcional)</label>
          <textarea id="mensaje" name="mensaje" placeholder="Describí brevemente el problema o la consulta..."></textarea>
        </div>
        <button type="submit" class="btn-submit">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          Enviar por WhatsApp
        </button>
        <p class="form-note">Al enviar se abre WhatsApp con tu consulta lista para mandar.</p>
      </form>

    </div>
  </div>
</section>

<script is:inline define:vars={{
  waNumber: PHONE.raw,
  allZonas: [
    ...ZONAS.nucleo.map(z => ({ name: z, type: 'nucleo' })),
    ...ZONAS.centrica.map(z => ({ name: z, type: 'centrica' })),
    ...ZONAS.extendida.map(z => ({ name: z, type: 'extendida' })),
  ],
  msgEmpresa: COBERTURA.empresaRemota,
  msgExtendida: 'Llegamos a tu zona para trabajos de empresa (3 o más equipos). Consultanos.',
}}>
  document.addEventListener('DOMContentLoaded', function () {
    var form = document.getElementById('contact-form');
    if (!form) return;

    // --- Autocompletado de zonas ---
    var zonaInput = document.getElementById('zona');
    var sugList = document.getElementById('zona-suggestions');
    var zonaHint = document.getElementById('zona-hint');
    if (zonaInput && sugList && zonaHint) {
      function norm(s) {
        return s.toLowerCase()
          .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
          .replace(/\./g, '')
          .trim();
      }

      var activeIdx = -1;

      function showSuggestions(val) {
        var q = norm(val);
        if (q.length < 2) { hideSuggestions(); return; }

        var matches = allZonas.filter(function(z) {
          return norm(z.name).indexOf(q) !== -1;
        }).slice(0, 6);

        if (matches.length === 0) {
          sugList.style.display = 'none';
          zonaHint.textContent = msgEmpresa;
          zonaHint.className = 'zona-hint zona-hint--warn';
          zonaHint.style.display = '';
          return;
        }

        zonaHint.style.display = 'none';
        activeIdx = -1;
        sugList.innerHTML = matches.map(function(z, i) {
          var badge = '';
          if (z.type === 'extendida') {
            badge = '<span class="sug-badge sug-badge--ext">Empresas 3+</span>';
          }
          return '<li role="option" data-idx="' + i + '" data-name="' + z.name + '" data-type="' + z.type + '">'
            + '<span class="sug-check">✓</span>'
            + '<span class="sug-name">' + z.name + '</span>'
            + badge
            + '</li>';
        }).join('');
        sugList.style.display = '';
      }

      function hideSuggestions() {
        sugList.style.display = 'none';
        activeIdx = -1;
      }

      function selectZona(name, type) {
        zonaInput.value = name;
        hideSuggestions();
        if (type === 'extendida') {
          zonaHint.textContent = msgExtendida;
          zonaHint.className = 'zona-hint zona-hint--info';
          zonaHint.style.display = '';
        } else {
          zonaHint.style.display = 'none';
        }
      }

      zonaInput.addEventListener('input', function () {
        showSuggestions(zonaInput.value);
      });

      zonaInput.addEventListener('focus', function () {
        if (zonaInput.value.length >= 2) showSuggestions(zonaInput.value);
      });

      // Clic en sugerencia
      sugList.addEventListener('mousedown', function (e) {
        var li = e.target.closest('li');
        if (li) selectZona(li.dataset.name, li.dataset.type);
      });

      // Navegación con teclado
      zonaInput.addEventListener('keydown', function (e) {
        var items = sugList.querySelectorAll('li');
        if (!items.length || sugList.style.display === 'none') return;

        if (e.key === 'ArrowDown') {
          e.preventDefault();
          activeIdx = Math.min(activeIdx + 1, items.length - 1);
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          activeIdx = Math.max(activeIdx - 1, 0);
        } else if (e.key === 'Enter' && activeIdx >= 0) {
          e.preventDefault();
          selectZona(items[activeIdx].dataset.name, items[activeIdx].dataset.type);
          return;
        } else if (e.key === 'Escape') {
          hideSuggestions();
          return;
        } else {
          return;
        }
        items.forEach(function(li, i) {
          li.classList.toggle('is-active', i === activeIdx);
        });
      });

      // Cerrar al perder foco
      zonaInput.addEventListener('blur', function () {
        setTimeout(hideSuggestions, 150);
      });
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();

      var nombre   = form.nombre.value.trim();
      var servicio = form.servicio.value;
      var zona     = form.zona.value.trim();
      var telefono = form.telefono.value.trim();
      var mensaje  = form.mensaje.value.trim();

      var texto = 'Hola, vengo de la web.';
      if (nombre)   texto += ' Soy ' + nombre + '.';
      if (zona)     texto += ' Zona: ' + zona + '.';
      if (telefono) texto += ' Tel: ' + telefono + '.';
      if (servicio) texto += ' Necesito: ' + servicio + '.';
      if (mensaje)  texto += ' ' + mensaje;
      texto += ' 📋';

      // Guardar lead en Google Sheets (fire-and-forget)
      var SHEETS_URL = window.__SHEETS_WEBHOOK__;
      if (SHEETS_URL) {
        try {
          fetch(SHEETS_URL, {
            method: 'POST',
            mode: 'no-cors',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              nombre: nombre,
              telefono: telefono,
              zona: zona,
              servicio: servicio,
              mensaje: mensaje,
              origen: 'web-contacto',
              fecha: new Date().toISOString(),
            }),
          });
        } catch (_) { /* no bloquear si falla */ }
      }

      // Evento de conversión
      if (typeof window.trackWaClick === 'function') {
        window.trackWaClick('contacto');
      }

      var url = 'https://wa.me/' + waNumber + '?text=' + encodeURIComponent(texto);
      window.open(url, '_blank', 'noopener,noreferrer');
    });
  });
</script>

<style>
  .contacto {
    background: #111;
    padding: 80px 24px;
    position: relative;
    overflow: hidden;
  }
  .contacto::before {
    content: '';
    position: absolute;
    top: -80px; left: 50%; transform: translateX(-50%);
    width: 600px; height: 400px;
    background: radial-gradient(ellipse, rgba(255,123,3,0.1) 0%, transparent 65%);
    pointer-events: none;
  }

  .inner {
    max-width: 980px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }
  @media (min-width: 720px) {
    .layout { grid-template-columns: 1fr 1.2fr; align-items: start; }
  }

  /* Info */
  .eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brand);
    margin-bottom: 12px;
  }
  h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 16px;
  }
  h2 em {
    font-style: normal;
    color: var(--brand);
  }
  .lead {
    font-size: 15px;
    color: rgba(255,255,255,0.45);
    line-height: 1.7;
    margin-bottom: 28px;
  }

  .contact-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .contact-item {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .contact-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: rgba(255,255,255,0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.5);
    flex-shrink: 0;
  }
  .contact-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
    font-size: 14px;
    color: rgba(255,255,255,0.6);
  }
  .contact-text strong {
    font-size: 11px;
    font-weight: 700;
    color: rgba(255,255,255,0.3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* Formulario */
  .form-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .form-row label {
    font-size: 12px;
    font-weight: 700;
    color: rgba(255,255,255,0.45);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .form-row input,
  .form-row select,
  .form-row textarea {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    padding: 12px 14px;
    font-size: 14px;
    color: #fff;
    font-family: inherit;
    outline: none;
    width: 100%;
    transition: border-color 0.2s;
  }
  .form-row input::placeholder,
  .form-row textarea::placeholder { color: rgba(255,255,255,0.2); }
  .form-row select { color: rgba(255,255,255,0.6); }
  .form-row select option { background: #1a1a1a; color: #fff; }
  .form-row input:focus,
  .form-row select:focus,
  .form-row textarea:focus { border-color: var(--brand); }
  .form-row textarea { resize: none; height: 100px; }

  .btn-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px;
    background: var(--brand);
    color: #fff;
    font-size: 15px;
    font-weight: 700;
    border-radius: 12px;
    border: none;
    cursor: pointer;
    font-family: inherit;
    width: 100%;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-submit:hover {
    background: var(--brand-d);
    transform: translateY(-1px);
  }

  .form-note {
    font-size: 11px;
    color: rgba(255,255,255,0.2);
    text-align: center;
  }

  /* Autocompletado de zona */
  .zona-row { position: relative; }
  .zona-wrap { position: relative; }
  .zona-suggestions {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    z-index: 10;
    background: #2a2a2a;
    border: 1px solid rgba(255,123,3,0.3);
    border-radius: 12px;
    padding: 6px;
    list-style: none;
    max-height: 220px;
    overflow-y: auto;
    box-shadow: 0 16px 48px rgba(0,0,0,0.7), 0 0 0 1px rgba(255,255,255,0.06);
  }
  .zona-suggestions :global(li) {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 12px;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.12s;
  }
  .zona-suggestions :global(li:hover),
  .zona-suggestions :global(li.is-active) {
    background: rgba(255,123,3,0.12);
  }
  .zona-suggestions :global(.sug-check) {
    font-size: 12px;
    color: #22c55e;
    font-weight: 800;
    flex-shrink: 0;
    width: 18px;
    text-align: center;
  }
  .zona-suggestions :global(.sug-name) {
    font-size: 14px;
    color: #fff;
    font-weight: 600;
  }
  .zona-suggestions :global(li:hover .sug-name),
  .zona-suggestions :global(li.is-active .sug-name) {
    color: var(--brand);
  }

  /* Hint para zonas no listadas */
  .zona-hint {
    font-size: 12px;
    line-height: 1.5;
    padding: 8px 12px;
    border-radius: 8px;
    margin-top: 4px;
  }
  .zona-hint--warn {
    background: rgba(255, 183, 0, 0.1);
    border: 1px solid rgba(255, 183, 0, 0.25);
    color: #FFB700;
  }
  .zona-hint--info {
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.25);
    color: #60A5FA;
  }

  /* Badge extendida en sugerencias */
  .zona-suggestions :global(.sug-badge) {
    font-size: 10px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 6px;
    margin-left: auto;
    flex-shrink: 0;
  }
  .zona-suggestions :global(.sug-badge--ext) {
    background: rgba(59, 130, 246, 0.15);
    color: #60A5FA;
  }
</style>
