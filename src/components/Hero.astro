---
const WA = "https://wa.me/5491166082608?text=" + encodeURIComponent("Hola, vengo de la web. Quiero coordinar una visita técnica.");
---

<section class="hero" id="inicio">

  <!-- Decoración de fondo -->
  <div class="glow-orange" aria-hidden="true"></div>
  <div class="glow-red"    aria-hidden="true"></div>
  <div class="line-l"      aria-hidden="true"></div>
  <div class="line-r"      aria-hidden="true"></div>

  <div class="hero-inner">

    <!-- Eyebrow -->
    <div class="eyebrow">
      <span class="pulse" aria-hidden="true"></span>
      <span class="eyebrow-main">Servicio técnico de dispenser</span>
      <span class="eyebrow-sep" aria-hidden="true"> · </span>
      <span class="eyebrow-zone">CABA y AMBA</span>
    </div>

    <!-- Título -->
    <h1>
      Reparación y limpieza<br />
      de dispenser <em>a domicilio</em>
    </h1>

    <!-- Descripción -->
    <p class="lead">
      Servicio técnico de dispensers a domicilio para oficinas, consultorios,
      industrias y particulares. Reparación, limpieza y mantenimiento con
      garantía incluida.
    </p>

    <!-- Badge WhatsApp IA -->
    <div class="wa-badge-wrap">
      <div class="wa-badge">
        <span class="wa-dot" aria-hidden="true"></span>
        <strong>Respondemos al instante</strong>
        <span class="sep" aria-hidden="true">·</span>
        Visita en 24 a 48 horas
      </div>
    </div>

    <!-- CTAs -->
    <div class="hero-cta">
      <a href={WA} class="btn-primary" target="_blank" rel="noopener noreferrer">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Coordinar visita
      </a>
      <a href="#servicios" class="btn-ghost">Ver servicios</a>
    </div>
    <p class="cta-note">Sin turno previo · Visita en 24 a 48 hs</p>

    <!-- Línea de prueba social compacta -->
    <p class="trust-line" aria-label="Reputación verificada">
      <span class="trust-stars">★ 4.9 en Google</span>
      <span class="trust-sep" aria-hidden="true">·</span>
      <span>40 reseñas verificadas</span>
      <span class="trust-sep" aria-hidden="true">·</span>
      <span>7+ años en CABA y AMBA</span>
    </p>

    <!-- Chips de reseñas -->
    <div class="review-chips">
      <div class="chip">
        <div class="chip-stars" aria-label="5 estrellas">★★★★★</div>
        <p class="chip-text">"Como hace 5 años seguimos eligiendo LA TIENDA. Trabajo prolijo, buena atención y costos accesibles."</p>
        <span class="chip-author">Mir viru · Cliente desde hace 5 años</span>
      </div>
      <div class="chip">
        <div class="chip-stars" aria-label="5 estrellas">★★★★★</div>
        <p class="chip-text">"Urgencia un sábado, en un par de horas pasaron a revisarlo. Encontraron el problema y lo solucionaron."</p>
        <span class="chip-author">Braian Gonzalez · Hace 2 meses</span>
      </div>
    </div>

  </div>
</section>

<style>
  /* ===== Sección ===== */
  .hero {
    background: #0f0f0f;
    padding: 70px 20px 60px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  @media (min-width: 640px) {
    .hero { padding: 100px 40px 90px; }
  }

  /* Borde superior naranja */
  .hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent 5%, var(--brand) 50%, transparent 95%);
  }
  /* Borde inferior sutil */
  .hero::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,123,3,0.3), transparent);
  }

  /* Glows de fondo */
  .glow-orange {
    position: absolute;
    top: -120px; left: 50%; transform: translateX(-50%);
    width: 700px; height: 560px;
    background: radial-gradient(ellipse, rgba(255,123,3,0.13) 0%, transparent 65%);
    pointer-events: none;
  }
  .glow-red {
    position: absolute;
    bottom: -80px; right: -60px;
    width: 380px; height: 380px;
    background: radial-gradient(ellipse, rgba(229,68,58,0.09) 0%, transparent 65%);
    pointer-events: none;
  }

  /* Líneas decorativas — solo desktop */
  .line-l, .line-r { display: none; }
  @media (min-width: 768px) {
    .line-l {
      display: block;
      position: absolute; top: 0; bottom: 0; left: 22%; width: 1px;
      background: linear-gradient(to bottom, transparent, rgba(255,123,3,0.1), transparent);
    }
    .line-r {
      display: block;
      position: absolute; top: 0; bottom: 0; right: 22%; width: 1px;
      background: linear-gradient(to bottom, transparent, rgba(255,123,3,0.1), transparent);
    }
  }

  /* Contenedor interno */
  .hero-inner {
    max-width: 820px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* Eyebrow */
  .eyebrow {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    background: rgba(255,123,3,0.12);
    border: 1px solid rgba(255,123,3,0.22);
    color: var(--brand);
    padding: 6px 14px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 24px;
  }
  /* En mobile: "CABA y AMBA" en línea propia */
  @media (max-width: 639px) {
    .eyebrow-sep { display: none; }
    .eyebrow-zone {
      width: 100%;
      text-align: center;
    }
  }
  .pulse {
    width: 7px; height: 7px;
    background: var(--brand);
    border-radius: 50%;
    animation: pulse 2s infinite;
    flex-shrink: 0;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(1.4); }
  }

  /* Título */
  h1 {
    font-size: clamp(2rem, 8vw, 4.2rem);
    font-weight: 900;
    line-height: 1.06;
    letter-spacing: -0.03em;
    color: #fff;
    margin-bottom: 20px;
  }
  h1 em {
    font-style: normal;
    color: var(--brand);
  }
  /* En mobile: "a domicilio" en línea propia */
  @media (max-width: 639px) {
    h1 em { display: block; }
  }

  /* Lead */
  .lead {
    font-size: clamp(15px, 2.5vw, 18px);
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
    max-width: 54ch;
    margin: 0 auto 26px;
  }

  /* Badge WhatsApp */
  .wa-badge-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 26px;
  }
  .wa-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
    background: rgba(37,211,102,0.08);
    border: 1px solid rgba(37,211,102,0.2);
    border-radius: 12px;
    padding: 10px 16px;
    font-size: 13px;
    color: rgba(255,255,255,0.6);
    font-weight: 500;
  }
  .wa-badge strong { color: #25d366; }
  .wa-dot {
    width: 8px; height: 8px;
    background: #25d366;
    border-radius: 50%;
    animation: pulse 2s infinite;
    flex-shrink: 0;
  }
  .sep { color: rgba(255,255,255,0.2); }

  /* CTAs */
  .hero-cta {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 26px;
    background: var(--brand);
    color: #fff;
    font-weight: 700;
    font-size: 15px;
    border-radius: 13px;
    box-shadow: 0 8px 24px rgba(255,123,3,0.3);
    transition: background 0.2s, transform 0.15s;
  }
  .btn-primary:hover {
    background: var(--brand-d);
    transform: translateY(-1px);
  }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 13px 26px;
    background: transparent;
    border: 1.5px solid rgba(255,255,255,0.18);
    color: rgba(255,255,255,0.8);
    font-weight: 700;
    font-size: 15px;
    border-radius: 13px;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-ghost:hover {
    border-color: var(--brand);
    color: var(--brand);
  }
  .cta-note {
    font-size: 12px;
    color: rgba(255,255,255,0.25);
    margin-bottom: 44px;
    margin-top: 10px;
  }

  /* Línea de prueba social compacta */
  .trust-line {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 8px 14px;
    font-size: 13px;
    color: rgba(255,255,255,0.65);
    margin: 0 auto 28px;
    max-width: 560px;
  }
  .trust-stars {
    color: #FFB800;
    font-weight: 700;
  }
  .trust-sep {
    color: rgba(255,255,255,0.25);
  }

  /* Chips de reseñas */
  .review-chips {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .chip {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px;
    padding: 14px 18px;
    width: 100%;
    max-width: 310px;
    text-align: left;
    transition: border-color 0.2s;
  }
  .chip:hover { border-color: rgba(255,123,3,0.25); }
  .chip-stars {
    color: #FFB800;
    font-size: 13px;
    margin-bottom: 8px;
  }
  .chip-text {
    font-size: 13px;
    color: rgba(255,255,255,0.45);
    font-style: italic;
    line-height: 1.55;
    margin-bottom: 8px;
  }
  .chip-author {
    font-size: 11px;
    font-weight: 700;
    color: rgba(255,255,255,0.55);
  }
</style>
