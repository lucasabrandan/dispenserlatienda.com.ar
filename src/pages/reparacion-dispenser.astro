---
import Layout from "../layouts/Layout.astro";
import { WA, SITE, COBERTURA, PHONE } from "../config/site";

const title = `Reparación de Dispensers a Domicilio | ${COBERTURA.short} | ${SITE.name}`;
const description = `Reparamos tu dispenser en tu domicilio u oficina. Diagnóstico previo por WhatsApp, presupuesto sin compromiso y garantía de 3 meses. ${COBERTURA.short}. ${PHONE.display}.`;

const schemaService = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Reparación de dispensers de agua a domicilio",
  "description": description,
  "provider": {
    "@type": "LocalBusiness",
    "name": SITE.name,
    "telephone": PHONE.international,
    "url": SITE.url,
  },
  "areaServed": ["Ciudad Autónoma de Buenos Aires", "Zona Sur del Gran Buenos Aires"],
  "serviceType": "Reparación de dispensers de agua",
};

const SERVICIOS_RELACIONADOS = [
  { label: "Limpieza y cambio de filtro", href: "/limpieza-y-cambio-de-filtro" },
  { label: "Conversión de bidón a red", href: "/conversion-bidon-a-red" },
  { label: "Alquiler corporativo", href: "/alquiler-corporativo" },
];
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaService)} />

  <!-- Hero -->
  <section class="srv-hero">
    <div class="srv-hero-inner">
      <a href="/" class="srv-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Volver al inicio
      </a>
      <span class="srv-eyebrow">Servicio técnico a domicilio</span>
      <h1>Reparación de <em>dispensers</em></h1>
      <p class="srv-lead">
        Diagnosticamos el problema por WhatsApp antes de ir. Te pasamos un estimativo,
        y si lo confirmás, coordinamos día y horario para la visita.
        Sin traslados, sin turnos, sin sorpresas.
      </p>
      <div class="srv-cta-row">
        <a href={WA.reparacion} class="btn-primary" target="_blank" rel="noopener noreferrer" data-wa-event="reparacion-page">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          Consultar por WhatsApp
        </a>
        <a href="/#contacto" class="btn-ghost">Completar formulario</a>
      </div>
      <p class="srv-note">Respuesta inmediata · Visita en 24 a 48 hs · {COBERTURA.short}</p>
    </div>
  </section>

  <!-- Cómo funciona -->
  <section class="srv-section srv-section--light">
    <div class="srv-inner">
      <span class="srv-eyebrow">Cómo funciona</span>
      <h2>Del problema a la solución<br>en <em>4 pasos</em></h2>

      <div class="steps">
        <div class="step">
          <span class="step-num">1</span>
          <h3>Escribinos por WhatsApp</h3>
          <p>Contanos qué le pasa al equipo. Si podés, mandanos fotos del dispenser y del modelo.</p>
        </div>
        <div class="step">
          <span class="step-num">2</span>
          <h3>Diagnóstico previo</h3>
          <p>Analizamos las fotos y te damos un estimativo de costo antes de ir. Sin compromiso.</p>
        </div>
        <div class="step">
          <span class="step-num">3</span>
          <h3>Visita a domicilio</h3>
          <p>Coordinamos día y horario que te sirva. El técnico va con las herramientas y repuestos necesarios.</p>
        </div>
        <div class="step">
          <span class="step-num">4</span>
          <h3>Equipo funcionando</h3>
          <p>Reparación en el momento, probamos el equipo y te damos 3 meses de garantía sobre el trabajo.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Qué reparamos -->
  <section class="srv-section srv-section--dark">
    <div class="srv-inner">
      <span class="srv-eyebrow">Qué reparamos</span>
      <h2>Problemas que <em>resolvemos</em></h2>

      <div class="problems-grid">
        <div class="problem-card">
          <h3>No enfría o no calienta</h3>
          <p>Falla de compresor, resistencia quemada, termostato desregulado o falta de ventilación. Diagnosticamos y reparamos en la visita.</p>
        </div>
        <div class="problem-card">
          <h3>Pierde agua</h3>
          <p>Uniones sueltas, flotante trabado, válvulas dañadas o fisura interna. Identificamos el origen y lo sellamos o reemplazamos.</p>
        </div>
        <div class="problem-card">
          <h3>Da corriente o descarga</h3>
          <p>Problema eléctrico que requiere intervención urgente. Revisamos aislación, cableado y puesta a tierra del equipo.</p>
        </div>
        <div class="problem-card">
          <h3>Olor a quemado</h3>
          <p>Puede ser sobrecalentamiento del compresor o falla eléctrica. Hacemos diagnóstico completo antes de cualquier intervención.</p>
        </div>
        <div class="problem-card">
          <h3>Agua con gusto u olor</h3>
          <p>Filtro saturado o circuito interno contaminado. Se resuelve con limpieza profunda y cambio de filtro.</p>
        </div>
        <div class="problem-card">
          <h3>Funciona a veces sí, a veces no</h3>
          <p>Falla intermitente en el termostato, conexión floja o componente en deterioro. Necesita revisión técnica para identificar la causa.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ específica -->
  <section class="srv-section srv-section--light">
    <div class="srv-inner">
      <span class="srv-eyebrow">Preguntas frecuentes</span>
      <h2>Sobre la <em>reparación</em></h2>

      <div class="srv-faq">
        <details class="srv-faq-item">
          <summary>¿Cuánto sale reparar un dispenser?</summary>
          <p>Depende de la falla. Por eso hacemos diagnóstico previo por WhatsApp: con fotos del equipo te pasamos un estimativo antes de ir. Sin compromiso.</p>
        </details>
        <details class="srv-faq-item">
          <summary>¿Reparan todas las marcas?</summary>
          <p>Sí. Trabajamos con todas las marcas de dispensers de agua: nacionales e importados, de bidón y de red.</p>
        </details>
        <details class="srv-faq-item">
          <summary>¿Tienen garantía las reparaciones?</summary>
          <p>Sí. Damos 3 meses de garantía sobre el trabajo realizado. Si el problema reaparece, volvemos sin costo.</p>
        </details>
        <details class="srv-faq-item">
          <summary>¿Qué pasa si van y no se puede reparar?</summary>
          <p>Si el técnico va a domicilio y el equipo no tiene arreglo, se cobra la mitad del valor de la visita por el diagnóstico realizado. Te lo avisamos siempre antes de ir.</p>
        </details>
        <details class="srv-faq-item">
          <summary>¿Hacen carga de gas o reparan motores/compresores?</summary>
          <p>No. No trabajamos con carga de gas refrigerante ni reparación de motores o compresores. Si el problema es de compresor, te lo informamos en el diagnóstico para que evalúes si conviene reparar o reemplazar el equipo.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA final + servicios relacionados -->
  <section class="srv-section srv-section--cta">
    <div class="srv-inner" style="text-align:center;">
      <h2>¿Tu dispenser tiene <em>un problema</em>?</h2>
      <p class="srv-lead">Mandanos fotos por WhatsApp y te damos un estimativo en el momento.</p>
      <a href={WA.reparacion} class="btn-primary" target="_blank" rel="noopener noreferrer" data-wa-event="reparacion-page-cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Consultar por WhatsApp
      </a>

      <div class="srv-related">
        <p class="srv-related-label">Otros servicios</p>
        <div class="srv-related-links">
          {SERVICIOS_RELACIONADOS.map(s => (
            <a href={s.href} class="srv-related-link">{s.label}</a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ===== Hero ===== */
  .srv-hero {
    background: #0f0f0f;
    padding: 48px 20px 60px;
    position: relative;
    overflow: hidden;
  }
  .srv-hero::before {
    content: '';
    position: absolute;
    top: -100px; left: 50%; transform: translateX(-50%);
    width: 600px; height: 450px;
    background: radial-gradient(ellipse, rgba(255,123,3,0.12) 0%, transparent 65%);
    pointer-events: none;
  }
  .srv-hero-inner {
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .srv-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: rgba(255,255,255,0.4);
    margin-bottom: 24px;
    transition: color 0.2s;
  }
  .srv-back:hover { color: var(--brand); }

  .srv-eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brand);
    margin-bottom: 12px;
  }
  h1 {
    font-size: clamp(2rem, 6vw, 3.4rem);
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: #fff;
    margin-bottom: 20px;
  }
  h1 em { font-style: normal; color: var(--brand); }

  .srv-lead {
    font-size: clamp(15px, 2.5vw, 17px);
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
    max-width: 56ch;
    margin-bottom: 28px;
  }

  .srv-cta-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 26px;
    background: var(--brand);
    color: #fff;
    font-weight: 700;
    font-size: 15px;
    border-radius: 13px;
    box-shadow: 0 8px 24px rgba(255,123,3,0.3);
    transition: background 0.2s, transform 0.15s;
  }
  .btn-primary:hover { background: var(--brand-d); transform: translateY(-1px); }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 13px 26px;
    background: transparent;
    border: 1.5px solid rgba(255,255,255,0.18);
    color: rgba(255,255,255,0.8);
    font-weight: 700;
    font-size: 15px;
    border-radius: 13px;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-ghost:hover { border-color: var(--brand); color: var(--brand); }

  .srv-note {
    font-size: 12px;
    color: rgba(255,255,255,0.25);
  }

  /* ===== Secciones genéricas ===== */
  .srv-section { padding: 72px 24px; }
  .srv-section--light { background: #F8F8F8; }
  .srv-section--dark { background: #111; }
  .srv-section--cta { background: #0f0f0f; padding: 80px 24px; }
  .srv-inner { max-width: 860px; margin: 0 auto; }

  .srv-section h2 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 36px;
  }
  .srv-section--light h2 { color: #111; }
  .srv-section--dark h2, .srv-section--cta h2 { color: #fff; }
  .srv-section h2 em { font-style: normal; color: var(--brand); }

  .srv-section--cta .srv-lead { margin: 0 auto 28px; }

  /* ===== Pasos ===== */
  .steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 640px) {
    .steps { grid-template-columns: 1fr 1fr; }
  }
  .step {
    background: #fff;
    border: 1px solid #E5E7EB;
    border-radius: 16px;
    padding: 28px 24px;
  }
  .step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 9px;
    background: var(--brand-lt);
    color: var(--brand);
    font-size: 14px;
    font-weight: 800;
    margin-bottom: 14px;
  }
  .step h3 {
    font-size: 15px;
    font-weight: 800;
    color: #111;
    margin-bottom: 8px;
  }
  .step p {
    font-size: 14px;
    color: #6b7280;
    line-height: 1.65;
  }

  /* ===== Problemas ===== */
  .problems-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 640px) {
    .problems-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 900px) {
    .problems-grid { grid-template-columns: 1fr 1fr 1fr; }
  }
  .problem-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 24px 20px;
  }
  .problem-card h3 {
    font-size: 15px;
    font-weight: 800;
    color: #fff;
    margin-bottom: 8px;
  }
  .problem-card p {
    font-size: 13px;
    color: rgba(255,255,255,0.45);
    line-height: 1.65;
  }

  /* ===== FAQ ===== */
  .srv-faq {
    border: 1px solid #E5E7EB;
    border-radius: 18px;
    overflow: hidden;
    max-width: 680px;
  }
  .srv-faq-item {
    border-bottom: 1px solid #E5E7EB;
  }
  .srv-faq-item:last-child { border-bottom: none; }
  .srv-faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 22px;
    font-size: 14px;
    font-weight: 600;
    color: #111;
    cursor: pointer;
    list-style: none;
    transition: background 0.15s;
  }
  .srv-faq-item summary::-webkit-details-marker { display: none; }
  .srv-faq-item summary:hover { background: #FAFAFA; }
  .srv-faq-item[open] summary { color: var(--brand); background: #FAFAFA; }
  .srv-faq-item p {
    padding: 0 22px 18px;
    font-size: 13px;
    color: #6b7280;
    line-height: 1.75;
  }

  /* ===== Servicios relacionados ===== */
  .srv-related {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .srv-related-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.35);
    margin-bottom: 16px;
  }
  .srv-related-links {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .srv-related-link {
    padding: 10px 20px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.6);
    transition: border-color 0.2s, color 0.2s;
  }
  .srv-related-link:hover {
    border-color: var(--brand);
    color: var(--brand);
  }
</style>
