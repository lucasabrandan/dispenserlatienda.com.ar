---
import Layout from "../layouts/Layout.astro";
import { WA, SITE, COBERTURA, PHONE, EMAIL } from "../config/site";

const title = `Alquiler Corporativo de Dispensers | Empresas | ${SITE.name}`;
const description = `Alquiler mensual de dispensers para empresas con servicio incluido: instalación, mantenimiento, filtros y soporte técnico. ${COBERTURA.short} y cobertura extendida para empresas.`;

const schemaService = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Alquiler corporativo de dispensers de agua",
  "description": description,
  "provider": {
    "@type": "LocalBusiness",
    "name": SITE.name,
    "telephone": PHONE.international,
    "url": SITE.url,
  },
  "areaServed": ["Ciudad Autónoma de Buenos Aires", "Gran Buenos Aires"],
  "serviceType": "Alquiler de dispensers de agua para empresas",
};

const subject = encodeURIComponent(`Consulta alquiler corporativo – ${SITE.name}`);
const body = encodeURIComponent(
  "Hola, me comunico desde la web para consultar por el alquiler corporativo de equipos.\n\n" +
  "Empresa / Razón social: \n" +
  "Cantidad de equipos: \n" +
  "Ubicación: \n" +
  "Contacto: \n\n" +
  "Quedo a la espera, gracias."
);
const MAIL = `mailto:${EMAIL}?subject=${subject}&body=${body}`;

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cuál es el mínimo de equipos para el alquiler corporativo?",
      "acceptedAnswer": { "@type": "Answer", "text": "El alquiler corporativo es a partir de 5 equipos. Para cantidades menores, podemos ofrecerte la venta de equipos con servicio de mantenimiento." },
    },
    {
      "@type": "Question",
      "name": "¿Cuánto dura el contrato de alquiler de dispensers?",
      "acceptedAnswer": { "@type": "Answer", "text": "Los contratos son flexibles. Consultanos y lo adaptamos a la necesidad de tu empresa." },
    },
    {
      "@type": "Question",
      "name": "¿Qué pasa si necesito más o menos equipos?",
      "acceptedAnswer": { "@type": "Answer", "text": "Se ajusta. Si tu empresa crece, sumamos equipos. Si reducís, los retiramos sin problema." },
    },
  ],
};

const SERVICIOS_RELACIONADOS = [
  { label: "Reparación de dispensers", href: "/reparacion-dispenser" },
  { label: "Limpieza y cambio de filtro", href: "/limpieza-y-cambio-de-filtro" },
  { label: "Conversión de bidón a red", href: "/conversion-bidon-a-red" },
];
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaService)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

  <!-- Hero -->
  <section class="srv-hero">
    <div class="srv-hero-inner">
      <a href="/" class="srv-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Volver al inicio
      </a>
      <span class="srv-eyebrow">Para empresas</span>
      <h1>Alquiler de dispensers<br>para <em>empresas</em></h1>
      <p class="srv-lead">
        Alquiler mensual con servicio todo incluido: instalación, mantenimiento preventivo,
        cambio de filtros y soporte técnico ante cualquier inconveniente.
        Vos solo usás el agua, del resto nos encargamos nosotros.
      </p>
      <div class="srv-cta-row">
        <a href={WA.alquiler} class="btn-primary" target="_blank" rel="noopener noreferrer" data-wa-event="alquiler-page">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          Consultar por WhatsApp
        </a>
        <a href={MAIL} class="btn-ghost">
          Pedir cotización por email
        </a>
      </div>
      <p class="srv-note">Solo para empresas · Mínimo 5 equipos</p>
    </div>
  </section>

  <!-- Qué incluye -->
  <section class="srv-section srv-section--light">
    <div class="srv-inner">
      <span class="srv-eyebrow">Todo incluido</span>
      <h2>Qué tenés con <em>el alquiler</em></h2>

      <div class="steps">
        <div class="step">
          <span class="step-num">1</span>
          <h3>Instalación</h3>
          <p>Llevamos los equipos, los instalamos y los dejamos funcionando. Sin costo adicional.</p>
        </div>
        <div class="step">
          <span class="step-num">2</span>
          <h3>Mantenimiento preventivo</h3>
          <p>Limpieza y cambio de filtros incluidos en el plan. Nos encargamos de agendar y coordinar.</p>
        </div>
        <div class="step">
          <span class="step-num">3</span>
          <h3>Soporte técnico incluido</h3>
          <p>Ante cualquier inconveniente, enviamos un técnico sin costo adicional. El soporte está incluido en el alquiler.</p>
        </div>
        <div class="step step--highlight">
          <span class="step-num">4</span>
          <h3>Facturación</h3>
          <p>Un solo monto mensual que incluye todo. Emitimos factura. Simple para la administración de tu empresa.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Para quién -->
  <section class="srv-section srv-section--dark">
    <div class="srv-inner">
      <span class="srv-eyebrow">Para quién es</span>
      <h2>Empresas de <em>todos los rubros</em></h2>

      <div class="problems-grid">
        <div class="problem-card">
          <h3>Oficinas y coworkings</h3>
          <p>Agua fría y caliente para tu equipo de trabajo, sin preocuparte por bidones ni mantenimiento.</p>
        </div>
        <div class="problem-card">
          <h3>Consultorios, clínicas y sanatorios</h3>
          <p>Agua disponible para pacientes y personal. Equipos limpios y mantenidos con frecuencia. Ya atendemos centros de salud en nuestra zona.</p>
        </div>
        <div class="problem-card">
          <h3>Industrias y depósitos</h3>
          <p>Equipos resistentes para uso intensivo. Soporte técnico incluido ante cualquier inconveniente.</p>
        </div>
      </div>

      <div class="testimonial">
        <div class="testimonial-stars" aria-label="5 estrellas">★★★★★</div>
        <p class="testimonial-text">"Realizamos el mantenimiento mensual con Dispenser La Tienda. Siempre puntuales, prolijos y con muy buena atención. Muy recomendable."</p>
        <span class="testimonial-author">— Luciano Garcia · Mantenimiento mensual</span>
      </div>

      <div class="srv-cta-row" style="margin-top:32px;">
        <a href={WA.alquiler} class="btn-primary" target="_blank" rel="noopener noreferrer" data-wa-event="alquiler-page-paraquien">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          Consultar por WhatsApp
        </a>
        <a href={MAIL} class="btn-ghost">Pedir cotización por email</a>
      </div>
    </div>
  </section>

  <!-- Cobertura extendida -->
  <section class="srv-section srv-section--light">
    <div class="srv-inner">
      <span class="srv-eyebrow">Cobertura corporativa</span>
      <h2>Llegamos a <em>toda la ciudad</em></h2>
      <p class="srv-sub">
        Para empresas con múltiples equipos, ampliamos la cobertura. Consultanos por tu zona.
      </p>
      <div class="cobertura-grid">
        <div class="cobertura-card">
          <h3>Capital Federal</h3>
          <p>Cobertura en todos los barrios de CABA. Respuesta inmediata para empresas.</p>
        </div>
        <div class="cobertura-card cobertura-card--highlight">
          <h3>Gran Buenos Aires</h3>
          <p>{COBERTURA.coberturaEmpresa}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="srv-section srv-section--light" style="padding-top:0;">
    <div class="srv-inner">
      <span class="srv-eyebrow">Preguntas frecuentes</span>
      <h2>Sobre el <em>alquiler</em></h2>

      <div class="srv-faq">
        <details class="srv-faq-item">
          <summary>¿Cuál es el mínimo de equipos?</summary>
          <p>El alquiler corporativo es a partir de 5 equipos. Para cantidades menores, podemos ofrecerte la venta de equipos con servicio de mantenimiento.</p>
        </details>
        <details class="srv-faq-item">
          <summary>¿Cuánto dura el contrato?</summary>
          <p>Los contratos son flexibles. Consultanos y lo adaptamos a la necesidad de tu empresa.</p>
        </details>
        <details class="srv-faq-item">
          <summary>¿Qué pasa si necesito más o menos equipos?</summary>
          <p>Se ajusta. Si tu empresa crece, sumamos equipos. Si reducís, los retiramos sin problema.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="srv-section srv-section--cta">
    <div class="srv-inner" style="text-align:center;">
      <h2>¿Tu empresa necesita <em>dispensers</em>?</h2>
      <p class="srv-lead">Contanos cuántos equipos necesitás y te armamos una cotización.</p>
      <div class="srv-cta-row" style="justify-content:center;">
        <a href={WA.alquiler} class="btn-primary" target="_blank" rel="noopener noreferrer" data-wa-event="alquiler-page-cta">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          Consultar por WhatsApp
        </a>
        <a href={MAIL} class="btn-ghost">Pedir cotización por email</a>
      </div>

      <div class="srv-related">
        <p class="srv-related-label">Otros servicios</p>
        <div class="srv-related-links">
          {SERVICIOS_RELACIONADOS.map(s => (
            <a href={s.href} class="srv-related-link">{s.label}</a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .srv-hero { background: #0f0f0f; padding: 48px 20px 60px; position: relative; overflow: hidden; }
  .srv-hero::before { content: ''; position: absolute; top: -100px; left: 50%; transform: translateX(-50%); width: 600px; height: 450px; background: radial-gradient(ellipse, rgba(255,123,3,0.12) 0%, transparent 65%); pointer-events: none; }
  .srv-hero-inner { max-width: 720px; margin: 0 auto; position: relative; z-index: 1; }
  .srv-back { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; color: rgba(255,255,255,0.4); margin-bottom: 24px; transition: color 0.2s; }
  .srv-back:hover { color: var(--brand); }
  .srv-eyebrow { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--brand); margin-bottom: 12px; }
  h1 { font-size: clamp(2rem, 6vw, 3.4rem); font-weight: 900; line-height: 1.08; letter-spacing: -0.03em; color: #fff; margin-bottom: 20px; }
  h1 em { font-style: normal; color: var(--brand); }
  .srv-lead { font-size: clamp(15px, 2.5vw, 17px); color: rgba(255,255,255,0.55); line-height: 1.7; max-width: 56ch; margin-bottom: 28px; }
  .srv-cta-row { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 12px; }
  .btn-primary { display: inline-flex; align-items: center; gap: 8px; padding: 13px 26px; background: var(--brand); color: #fff; font-weight: 700; font-size: 15px; border-radius: 13px; box-shadow: 0 8px 24px rgba(255,123,3,0.3); transition: background 0.2s, transform 0.15s; }
  .btn-primary:hover { background: var(--brand-d); transform: translateY(-1px); }
  .btn-ghost { display: inline-flex; align-items: center; padding: 13px 26px; background: transparent; border: 1.5px solid rgba(255,255,255,0.18); color: rgba(255,255,255,0.8); font-weight: 700; font-size: 15px; border-radius: 13px; transition: border-color 0.2s, color 0.2s; }
  .btn-ghost:hover { border-color: var(--brand); color: var(--brand); }
  .srv-note { font-size: 12px; color: rgba(255,255,255,0.25); }

  .srv-section { padding: 72px 24px; }
  .srv-section--light { background: #F8F8F8; }
  .srv-section--dark { background: #111; }
  .srv-section--cta { background: #0f0f0f; padding: 80px 24px; }
  .srv-inner { max-width: 860px; margin: 0 auto; }
  .srv-section h2 { font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 900; letter-spacing: -0.02em; line-height: 1.1; margin-bottom: 36px; }
  .srv-section--light h2 { color: #111; }
  .srv-section--dark h2, .srv-section--cta h2 { color: #fff; }
  .srv-section h2 em { font-style: normal; color: var(--brand); }
  .srv-section--cta .srv-lead { margin: 0 auto 28px; }
  .srv-sub { font-size: 15px; color: #6b7280; line-height: 1.7; margin-bottom: 28px; }

  .steps { display: grid; grid-template-columns: 1fr; gap: 24px; }
  @media (min-width: 640px) { .steps { grid-template-columns: 1fr 1fr; } }
  .step { background: #fff; border: 1px solid #E5E7EB; border-radius: 16px; padding: 28px 24px; }
  .step-num { display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 9px; background: var(--brand-lt); color: var(--brand); font-size: 14px; font-weight: 800; margin-bottom: 14px; }
  .step h3 { font-size: 15px; font-weight: 800; color: #111; margin-bottom: 8px; }
  .step p { font-size: 14px; color: #6b7280; line-height: 1.65; }
  .step--highlight { border-color: var(--brand); background: var(--brand-lt); }
  .step--highlight h3 { color: var(--brand-d); }

  .problems-grid { display: grid; grid-template-columns: 1fr; gap: 16px; }
  @media (min-width: 640px) { .problems-grid { grid-template-columns: 1fr 1fr 1fr; } }
  .problem-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 24px 20px; }
  .problem-card h3 { font-size: 15px; font-weight: 800; color: #fff; margin-bottom: 8px; }
  .problem-card p { font-size: 13px; color: rgba(255,255,255,0.45); line-height: 1.65; }

  .testimonial { margin-top: 32px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 24px; max-width: 520px; }
  .testimonial-stars { color: #FFB800; font-size: 14px; margin-bottom: 10px; }
  .testimonial-text { font-size: 14px; color: rgba(255,255,255,0.65); line-height: 1.7; font-style: italic; margin-bottom: 10px; }
  .testimonial-author { font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.35); }

  .cobertura-grid { display: grid; grid-template-columns: 1fr; gap: 16px; }
  @media (min-width: 640px) { .cobertura-grid { grid-template-columns: 1fr 1fr; } }
  .cobertura-card { background: #fff; border: 1px solid #E5E7EB; border-radius: 16px; padding: 24px 20px; }
  .cobertura-card h3 { font-size: 15px; font-weight: 800; color: #111; margin-bottom: 8px; }
  .cobertura-card p { font-size: 14px; color: #6b7280; line-height: 1.65; }
  .cobertura-card--highlight { border-color: var(--brand); background: var(--brand-lt); }
  .cobertura-card--highlight h3 { color: var(--brand-d); }

  .srv-faq { border: 1px solid #E5E7EB; border-radius: 18px; overflow: hidden; max-width: 680px; }
  .srv-faq-item { border-bottom: 1px solid #E5E7EB; }
  .srv-faq-item:last-child { border-bottom: none; }
  .srv-faq-item summary { display: flex; align-items: center; justify-content: space-between; padding: 18px 22px; font-size: 14px; font-weight: 600; color: #111; cursor: pointer; list-style: none; transition: background 0.15s; }
  .srv-faq-item summary::-webkit-details-marker { display: none; }
  .srv-faq-item summary:hover { background: #FAFAFA; }
  .srv-faq-item[open] summary { color: var(--brand); background: #FAFAFA; }
  .srv-faq-item p { padding: 0 22px 18px; font-size: 13px; color: #6b7280; line-height: 1.75; }

  .srv-related { margin-top: 48px; padding-top: 32px; border-top: 1px solid rgba(255,255,255,0.08); }
  .srv-related-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.35); margin-bottom: 16px; }
  .srv-related-links { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; }
  .srv-related-link { padding: 10px 20px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.6); transition: border-color 0.2s, color 0.2s; }
  .srv-related-link:hover { border-color: var(--brand); color: var(--brand); }
</style>
